{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/native-cpu/native-cpu-backend-capability-record-v0.schema.json",
  "title": "Stage 5D native CPU backend capability record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "backend_id",
    "stage_id",
    "native_backend_present",
    "native_backend_built",
    "native_backend_executable",
    "supported_thread_counts",
    "native_cpu_only",
    "cuda_used",
    "cuda_required",
    "gpu_required",
    "gpu_benchmark_performed",
    "cuda_kernel_added",
    "cuda_source_modified",
    "performance_claim",
    "speedup_claim",
    "broad_experiment_executed",
    "raw_data_processed",
    "solve_claim",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "codex_output_committed",
    "website_expansion",
    "python_semantic_reference_preserved",
    "cxx_launches_python_workers"
  ],
  "properties": {
    "record_type": { "const": "native_cpu_backend_capability_record" },
    "backend_id": { "type": "string", "minLength": 1 },
    "stage_id": { "const": "stage-5d" },
    "native_backend_present": { "type": "boolean" },
    "native_backend_built": { "type": "boolean" },
    "native_backend_executable": { "type": "string" },
    "supported_thread_counts": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 1
    },
    "native_cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "gpu_required": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "website_expansion": { "const": false },
    "python_semantic_reference_preserved": { "const": true },
    "cxx_launches_python_workers": { "const": false }
  }
}
