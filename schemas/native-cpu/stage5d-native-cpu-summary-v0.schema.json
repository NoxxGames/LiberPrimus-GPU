{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/native-cpu/stage5d-native-cpu-summary-v0.schema.json",
  "title": "Stage 5D native CPU summary",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "status",
    "backend_capability_records",
    "threading_records",
    "parity_records",
    "diagnostic_records",
    "thread_counts_tested",
    "one_thread_hash",
    "multi_thread_hash",
    "one_thread_equals_multi_thread",
    "python_native_parity",
    "native_backend_built",
    "native_backend_executable",
    "native_cpu_only",
    "cuda_used",
    "cuda_required",
    "gpu_required",
    "gpu_benchmark_performed",
    "cuda_kernel_added",
    "cuda_source_modified",
    "performance_claim",
    "speedup_claim",
    "timing_is_diagnostic_only",
    "broad_experiment_executed",
    "raw_data_processed",
    "solve_claim",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "codex_output_committed",
    "website_expansion",
    "python_semantic_reference_preserved",
    "cxx_launches_python_workers",
    "next_stage"
  ],
  "properties": {
    "record_type": { "const": "stage5d_native_cpu_summary" },
    "stage_id": { "const": "stage-5d" },
    "status": { "const": "complete" },
    "backend_capability_records": { "type": "integer", "minimum": 1 },
    "threading_records": { "type": "integer", "minimum": 1 },
    "parity_records": { "type": "integer", "minimum": 1 },
    "diagnostic_records": { "type": "integer", "minimum": 1 },
    "thread_counts_tested": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 2
    },
    "one_thread_hash": { "type": "string", "minLength": 16 },
    "multi_thread_hash": { "type": "string", "minLength": 16 },
    "one_thread_equals_multi_thread": { "type": "boolean" },
    "python_native_parity": { "type": "boolean" },
    "native_backend_built": { "type": "boolean" },
    "native_backend_executable": { "type": "string" },
    "native_cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "gpu_required": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "timing_is_diagnostic_only": { "const": true },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "website_expansion": { "const": false },
    "python_semantic_reference_preserved": { "const": true },
    "cxx_launches_python_workers": { "const": false },
    "next_stage": { "const": "Stage 5E - first CUDA kernel contract and CPU/native parity adapter selection" }
  }
}
