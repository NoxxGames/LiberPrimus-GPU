{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/native-cpu/native-cpu-threading-record-v0.schema.json",
  "title": "Stage 5D native CPU threading record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "threading_record_id",
    "stage_id",
    "backend_id",
    "fixture_id",
    "thread_count",
    "baseline_thread_count",
    "output_hash",
    "record_hash",
    "baseline_output_hash",
    "matches_baseline",
    "deterministic_ordering",
    "fixed_output_slots",
    "range_partitioning",
    "native_cpu_only",
    "cuda_used",
    "gpu_benchmark_performed",
    "solve_claim",
    "no_solve_claim",
    "python_semantic_reference_preserved",
    "cxx_launches_python_workers"
  ],
  "properties": {
    "record_type": { "const": "native_cpu_threading_record" },
    "threading_record_id": { "type": "string", "minLength": 1 },
    "stage_id": { "const": "stage-5d" },
    "backend_id": { "type": "string", "minLength": 1 },
    "fixture_id": { "type": "string", "minLength": 1 },
    "thread_count": { "type": "integer", "minimum": 1 },
    "baseline_thread_count": { "const": 1 },
    "output_hash": { "type": "string", "minLength": 16 },
    "record_hash": { "type": "string", "minLength": 16 },
    "baseline_output_hash": { "type": "string", "minLength": 16 },
    "matches_baseline": { "type": "boolean" },
    "deterministic_ordering": { "const": true },
    "fixed_output_slots": { "const": true },
    "range_partitioning": { "const": true },
    "native_cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "python_semantic_reference_preserved": { "const": true },
    "cxx_launches_python_workers": { "const": false }
  }
}
