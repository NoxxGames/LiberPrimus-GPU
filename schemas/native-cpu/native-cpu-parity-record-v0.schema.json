{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/native-cpu/native-cpu-parity-record-v0.schema.json",
  "title": "Stage 5D native CPU parity record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "parity_record_id",
    "stage_id",
    "backend_id",
    "fixture_id",
    "parity_scope",
    "native_output_hash",
    "python_reference_hash",
    "parity_passed",
    "deterministic_ordering",
    "native_cpu_only",
    "cuda_used",
    "cuda_required",
    "gpu_required",
    "gpu_benchmark_performed",
    "cuda_kernel_added",
    "cuda_source_modified",
    "performance_claim",
    "speedup_claim",
    "raw_data_processed",
    "solve_claim",
    "no_solve_claim",
    "generated_outputs_committed",
    "python_semantic_reference_preserved",
    "cxx_launches_python_workers"
  ],
  "properties": {
    "record_type": { "const": "native_cpu_parity_record" },
    "parity_record_id": { "type": "string", "minLength": 1 },
    "stage_id": { "const": "stage-5d" },
    "backend_id": { "type": "string", "minLength": 1 },
    "fixture_id": { "type": "string", "minLength": 1 },
    "parity_scope": { "enum": ["limited_synthetic_python_reference"] },
    "native_output_hash": { "type": "string", "minLength": 16 },
    "python_reference_hash": { "type": "string", "minLength": 16 },
    "parity_passed": { "type": "boolean" },
    "deterministic_ordering": { "const": true },
    "native_cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "gpu_required": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "generated_outputs_committed": { "const": false },
    "python_semantic_reference_preserved": { "const": true },
    "cxx_launches_python_workers": { "const": false }
  }
}
