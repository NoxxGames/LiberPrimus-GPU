{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "canonical_corpus_active": { "const": false },
    "corpus_candidate_id": { "type": "string" },
    "corpus_candidate_status": { "type": "string" },
    "direct_translation_expected": { "type": "boolean" },
    "expected_known_caveats": { "type": "array" },
    "expected_normalized_plaintext": { "type": ["string", "null"] },
    "expected_normalized_plaintext_sha256": { "type": ["string", "null"] },
    "expected_numeric_literal_count": { "type": ["integer", "null"] },
    "expected_rune_count": { "type": ["integer", "null"] },
    "expected_separator_policy": { "type": "string" },
    "fixture_id": { "type": "string" },
    "fixture_version": { "type": "string" },
    "gematria_profile_id": { "type": "string" },
    "gematria_profile_sha256": { "type": "string" },
    "glyph_variant_profile_id": { "type": "string" },
    "glyph_variant_profile_sha256": { "type": "string" },
    "in_scope_for_stage": { "type": "boolean" },
    "method_family": {
      "enum": [
        "direct_translation",
        "reverse_gematria",
        "vigenere",
        "rotated_reverse_gematria",
        "prime_minus_one_stream",
        "phi_prime_stream",
        "unknown"
      ]
    },
    "method_reference_sha256": { "type": "string" },
    "method_reference_source_id": { "type": "string" },
    "method_status": { "type": "string" },
    "notes": { "type": "array" },
    "page_boundaries_final": { "const": false },
    "payload_checks": { "type": "array" },
    "record_type": { "const": "solved_page_fixture" },
    "separator_grammar_id": { "type": "string" },
    "separator_grammar_sha256": { "type": "string" },
    "solved_reference_sha256": { "type": "string" },
    "solved_reference_source_id": { "type": "string" },
    "solved_section_aliases": { "type": "array" },
    "solved_section_title": { "type": "string" },
    "source_transcript_id": { "type": "string" },
    "source_transcript_sha256": { "type": "string" },
    "span_selector": {
      "additionalProperties": true,
      "properties": {
        "end_logical_line_index": { "type": ["integer", "null"] },
        "end_token_index": { "type": ["integer", "null"] },
        "notes": { "type": "string" },
        "page_candidate_ids": { "type": "array" },
        "selector_kind": {
          "enum": [
            "explicit_logical_line_range",
            "explicit_token_range",
            "page_candidate_reference",
            "section_title_reference",
            "pending"
          ]
        },
        "source": { "type": "string" },
        "start_logical_line_index": { "type": ["integer", "null"] },
        "start_token_index": { "type": ["integer", "null"] }
      },
      "required": ["selector_kind", "source"],
      "type": "object"
    },
    "span_status": { "type": "string" },
    "transform_chain": { "type": "array" },
    "trusted_as_canonical": { "const": false }
  },
  "required": [
    "record_type",
    "fixture_id",
    "fixture_version",
    "solved_section_title",
    "solved_section_aliases",
    "method_family",
    "method_status",
    "transform_chain",
    "direct_translation_expected",
    "in_scope_for_stage",
    "source_transcript_id",
    "source_transcript_sha256",
    "solved_reference_source_id",
    "solved_reference_sha256",
    "gematria_profile_id",
    "gematria_profile_sha256",
    "separator_grammar_id",
    "separator_grammar_sha256",
    "glyph_variant_profile_id",
    "glyph_variant_profile_sha256",
    "corpus_candidate_id",
    "corpus_candidate_status",
    "span_selector",
    "span_status",
    "expected_normalized_plaintext",
    "expected_normalized_plaintext_sha256",
    "expected_rune_count",
    "expected_numeric_literal_count",
    "expected_separator_policy",
    "expected_known_caveats",
    "trusted_as_canonical",
    "canonical_corpus_active",
    "page_boundaries_final",
    "notes"
  ],
  "type": "object"
}
