{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AL Publication Gate",
  "type": "object",
  "required": ["record_type", "stage_id", "status", "website_publication_allowed", "raw_content_publication_allowed", "generated_extract_publication_allowed", "private_ids_allowed", "raw_bodies_allowed", "solve_claim"],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5al" },
    "status": { "enum": ["metadata_only_safe", "private_deep_research_only", "generated_extract_review_required", "blocked_private_or_sensitive", "raw_source_never_publish", "public_website_review_required", "external_link_only"] },
    "website_publication_allowed": { "const": false },
    "raw_content_publication_allowed": { "const": false },
    "generated_extract_publication_allowed": { "const": false },
    "private_ids_allowed": { "const": false },
    "raw_bodies_allowed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
