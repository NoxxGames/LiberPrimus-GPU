{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AL Source Card Website-Ingest Record",
  "type": "object",
  "required": ["record_type", "stage_id", "source_id", "title", "publication_status", "private_deep_research_allowed", "website_publication_allowed", "raw_content_publication_allowed", "generated_extract_publication_allowed", "solve_claim"],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5al" },
    "source_id": { "type": "string" },
    "title": { "type": "string" },
    "publication_status": { "enum": ["metadata_only_safe", "private_deep_research_only", "generated_extract_review_required", "blocked_private_or_sensitive", "raw_source_never_publish", "public_website_review_required", "external_link_only"] },
    "private_deep_research_allowed": { "type": "boolean" },
    "website_publication_allowed": { "const": false },
    "raw_content_publication_allowed": { "const": false },
    "generated_extract_publication_allowed": { "const": false },
    "private_ids_published": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
