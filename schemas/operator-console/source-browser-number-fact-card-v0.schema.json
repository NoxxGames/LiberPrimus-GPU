{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "operation_type": {
      "enum": [
        "base_conversion",
        "count_equality",
        "cumulative_sum",
        "difference",
        "factorization",
        "gp_sum",
        "hash_contract",
        "matrix_grid_match",
        "modulo",
        "pixel_frequency",
        "prime_index_lookup",
        "product",
        "progressive_sum",
        "reverse_digits",
        "section_count_equality",
        "sequence_mapping",
        "source_observation",
        "sum",
        "symbolic_gp_scan",
        "unknown"
      ]
    },
    "review_state": {
      "enum": [
        "canonical_verification_required",
        "extracted_basic_fact",
        "overlay_enriched_fact",
        "quarantined_fact",
        "rich_fact_card",
        "vague_fact_enrichment_needed",
        "zero_extracted_facts_not_reviewed",
        "zero_extracted_facts_reviewed_none_found"
      ]
    },
    "usable_for_decision_now": {
      "const": false
    },
    "value_type": {
      "enum": [
        "coordinate",
        "difference",
        "duration_seconds",
        "factorization",
        "file_size",
        "gp_sum",
        "hash_length",
        "hash_value",
        "matrix_value",
        "modular_residue",
        "page_number",
        "pixel_count",
        "prime",
        "prime_index",
        "product",
        "ratio",
        "rgb_value",
        "rune_count",
        "sequence",
        "sum",
        "unknown",
        "word_count"
      ]
    },
    "verification_status": {
      "enum": [
        "arithmetic_verified_metadata_only",
        "canonical_image_required",
        "canonical_source_required",
        "canonical_transcript_required",
        "needs_exact_token_selection",
        "not_verified",
        "operator_assistant_observed",
        "quarantined_selection_bias",
        "reviewed_none_found",
        "source_author_claim",
        "verified_against_committed_source"
      ]
    }
  },
  "required": [
    "fact_uid",
    "source_entry_id",
    "source_record_path",
    "display_label",
    "review_state",
    "usable_for_decision_now"
  ],
  "type": "object"
}
