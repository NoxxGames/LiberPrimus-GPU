{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/benchmarks/cpu-benchmark-smoke-record-v0.schema.json",
  "title": "CPU Benchmark Smoke Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "benchmark_scope",
    "benchmark_status",
    "candidate_id",
    "input_stream_id",
    "transform_family",
    "output_token_hash",
    "output_text_hash",
    "timing_is_diagnostic",
    "performance_claim",
    "cpu_only",
    "cuda_used",
    "cuda_required",
    "gpu_benchmark_performed",
    "cuda_implementation_added",
    "no_solve_claim",
    "solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "raw_data_processed",
    "broad_experiment_executed"
  ],
  "properties": {
    "record_type": { "const": "cpu_benchmark_smoke_record" },
    "benchmark_scope": { "const": "cpu_smoke" },
    "benchmark_status": { "enum": ["smoke_passed", "smoke_failed", "skipped_optional"] },
    "candidate_id": { "type": "string", "minLength": 1 },
    "input_stream_id": { "type": "string", "minLength": 1 },
    "transform_family": { "type": "string", "minLength": 1 },
    "output_token_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "output_text_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "timing_is_diagnostic": { "const": true },
    "performance_claim": { "const": false },
    "cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "cuda_implementation_added": { "const": false },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "raw_data_processed": { "const": false },
    "broad_experiment_executed": { "const": false }
  }
}
