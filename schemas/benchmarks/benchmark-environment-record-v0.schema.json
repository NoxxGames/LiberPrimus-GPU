{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/benchmarks/benchmark-environment-record-v0.schema.json",
  "title": "Benchmark Environment Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "benchmark_scope",
    "benchmark_status",
    "environment_id",
    "python_version",
    "platform",
    "git_commit",
    "cpu_only",
    "cuda_used",
    "cuda_required",
    "gpu_benchmark_performed",
    "cuda_implementation_added",
    "no_solve_claim",
    "solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "raw_data_processed",
    "broad_experiment_executed"
  ],
  "properties": {
    "record_type": { "const": "benchmark_environment_record" },
    "benchmark_scope": { "const": "environment_record" },
    "benchmark_status": { "enum": ["planned", "skipped_optional"] },
    "environment_id": { "type": "string", "minLength": 1 },
    "python_version": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "minLength": 1 },
    "git_commit": { "type": "string", "minLength": 7 },
    "cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "cuda_implementation_added": { "const": false },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "raw_data_processed": { "const": false },
    "broad_experiment_executed": { "const": false }
  }
}
