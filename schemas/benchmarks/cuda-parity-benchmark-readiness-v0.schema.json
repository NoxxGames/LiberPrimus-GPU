{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/benchmarks/cuda-parity-benchmark-readiness-v0.schema.json",
  "title": "CUDA Parity Benchmark Readiness v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "readiness_id",
    "stage_id",
    "transform_family",
    "benchmark_scope",
    "benchmark_status",
    "parity_gate_status",
    "blockers",
    "cpu_reference_present",
    "stage4o_parity_expectation_available",
    "stage4p_unified_result_surface_available",
    "cpu_only",
    "cuda_used",
    "cuda_required",
    "gpu_benchmark_performed",
    "cuda_implementation_added",
    "no_solve_claim",
    "solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "raw_data_processed",
    "broad_experiment_executed"
  ],
  "properties": {
    "record_type": { "const": "cuda_parity_benchmark_readiness" },
    "readiness_id": { "type": "string", "minLength": 1 },
    "stage_id": { "const": "stage-4q" },
    "transform_family": { "type": "string", "minLength": 1 },
    "benchmark_scope": { "const": "parity_readiness" },
    "benchmark_status": { "enum": ["planned", "blocked", "skipped_optional"] },
    "parity_gate_status": {
      "enum": [
        "ready_for_future_cuda_planning",
        "blocked_missing_cpu_reference",
        "blocked_missing_parity_expectation",
        "blocked_missing_score_contract",
        "blocked_missing_unified_result_surface",
        "skipped_not_cuda_target"
      ]
    },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "cpu_reference_present": { "type": "boolean" },
    "stage4o_parity_expectation_available": { "type": "boolean" },
    "stage4p_unified_result_surface_available": { "type": "boolean" },
    "cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "cuda_implementation_added": { "const": false },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "raw_data_processed": { "const": false },
    "broad_experiment_executed": { "const": false }
  }
}
