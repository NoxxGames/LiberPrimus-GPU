{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/history/source-lock-snapshot-summary-v0.schema.json",
  "title": "Source Lock Snapshot Summary v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage",
    "sources_considered",
    "sources_allowlisted",
    "sources_fetched",
    "github_commit_blob_locks",
    "metadata_only_records",
    "ignored_local_snapshots",
    "committed_small_text_snapshots",
    "rejected_unsafe_noisy_sources",
    "duplicate_sources",
    "fetch_failures",
    "solve_claim",
    "raw_private_data_committed"
  ],
  "properties": {
    "record_type": { "const": "source_lock_snapshot_summary" },
    "stage": { "const": "Stage 4K" },
    "sources_considered": { "type": "integer", "minimum": 0 },
    "sources_allowlisted": { "type": "integer", "minimum": 0 },
    "sources_fetched": { "type": "integer", "minimum": 0 },
    "github_commit_blob_locks": { "type": "integer", "minimum": 0 },
    "metadata_only_records": { "type": "integer", "minimum": 0 },
    "ignored_local_snapshots": { "type": "integer", "minimum": 0 },
    "committed_small_text_snapshots": { "type": "integer", "minimum": 0 },
    "rejected_unsafe_noisy_sources": { "type": "integer", "minimum": 0 },
    "duplicate_sources": { "type": "integer", "minimum": 0 },
    "fetch_failures": { "type": "integer", "minimum": 0 },
    "source_lock_status_counts": { "type": "object" },
    "solve_claim": { "const": false },
    "raw_private_data_committed": { "const": false },
    "binary_committed": { "const": false },
    "image_committed": { "const": false },
    "audio_committed": { "const": false },
    "font_committed": { "const": false },
    "archive_committed": { "const": false }
  }
}
