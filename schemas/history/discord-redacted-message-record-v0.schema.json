{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/history/discord-redacted-message-record-v0.schema.json",
  "title": "Discord Redacted Message Record v0",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "archive_id",
    "source_file_sha256",
    "source_channel",
    "approximate_timestamp",
    "redaction_level",
    "redacted_text",
    "public_links",
    "attachment_filenames",
    "method_keywords",
    "numeric_values",
    "visual_keywords",
    "raw_message_committed",
    "username_committed",
    "user_id_committed",
    "message_id_committed",
    "private_url_committed",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "discord_redacted_message_record" },
    "record_id": { "type": "string", "minLength": 1 },
    "archive_id": { "type": "string", "minLength": 1 },
    "source_file_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source_channel": { "type": "string" },
    "approximate_timestamp": { "type": "string" },
    "redaction_level": { "enum": ["keyword_summary", "sanitized_excerpt", "aggregate_only"] },
    "redacted_text": { "type": "string" },
    "public_links": { "type": "array", "items": { "type": "string" } },
    "attachment_filenames": { "type": "array", "items": { "type": "string" } },
    "method_keywords": { "type": "array", "items": { "type": "string" } },
    "numeric_values": { "type": "array", "items": { "type": "integer" } },
    "visual_keywords": { "type": "array", "items": { "type": "string" } },
    "raw_message_committed": { "const": false },
    "username_committed": { "const": false },
    "user_id_committed": { "const": false },
    "message_id_committed": { "const": false },
    "private_url_committed": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
