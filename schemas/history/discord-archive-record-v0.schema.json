{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/history/discord-archive-record-v0.schema.json",
  "title": "Discord Archive Record v0",
  "type": "object",
  "required": [
    "record_type",
    "archive_id",
    "description",
    "source_status",
    "raw_logs_committed",
    "message_bodies_committed",
    "usernames_committed",
    "ai_upload_allowed",
    "live_api_used",
    "scrape_used",
    "local_path",
    "created_at_utc",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "discord_archive_record" },
    "archive_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "source_status": { "enum": ["admin_provided_export", "user_local_export", "unknown"] },
    "raw_logs_committed": { "const": false },
    "message_bodies_committed": { "const": false },
    "usernames_committed": { "const": false },
    "ai_upload_allowed": { "const": false },
    "live_api_used": { "const": false },
    "scrape_used": { "const": false },
    "local_path": { "type": "string" },
    "created_at_utc": { "type": "string" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
