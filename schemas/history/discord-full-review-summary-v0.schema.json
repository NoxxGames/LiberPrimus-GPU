{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/history/discord-full-review-summary-v0.schema.json",
  "title": "Discord Full Review Summary v0",
  "type": "object",
  "required": [
    "record_type",
    "run_id",
    "privacy_mode",
    "discord_html_file_count",
    "total_bytes_processed",
    "channel_count",
    "redacted_message_count",
    "channel_shard_count",
    "topic_shard_count",
    "public_link_count",
    "image_reference_count",
    "attachment_reference_count",
    "method_claim_count",
    "numeric_claim_count",
    "visual_claim_count",
    "debunk_count",
    "lp_page_image_count",
    "raw_discord_html_committed",
    "generated_site_committed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "discord_full_review_summary" },
    "run_id": { "type": "string", "minLength": 1 },
    "privacy_mode": { "const": "redacted_public" },
    "discord_html_file_count": { "type": "integer", "minimum": 0 },
    "total_bytes_processed": { "type": "integer", "minimum": 0 },
    "channel_count": { "type": "integer", "minimum": 0 },
    "redacted_message_count": { "type": "integer", "minimum": 0 },
    "channel_shard_count": { "type": "integer", "minimum": 0 },
    "topic_shard_count": { "type": "integer", "minimum": 0 },
    "public_link_count": { "type": "integer", "minimum": 0 },
    "image_reference_count": { "type": "integer", "minimum": 0 },
    "attachment_reference_count": { "type": "integer", "minimum": 0 },
    "method_claim_count": { "type": "integer", "minimum": 0 },
    "numeric_claim_count": { "type": "integer", "minimum": 0 },
    "visual_claim_count": { "type": "integer", "minimum": 0 },
    "debunk_count": { "type": "integer", "minimum": 0 },
    "lp_page_image_count": { "type": "integer", "minimum": 0 },
    "raw_message_committed": { "const": false },
    "username_committed": { "const": false },
    "user_id_committed": { "const": false },
    "message_id_committed": { "const": false },
    "private_url_committed": { "const": false },
    "raw_discord_html_committed": { "const": false },
    "generated_site_committed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
