{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/history/discord-ingestion-summary-v0.schema.json",
  "title": "Discord Ingestion Summary v0",
  "type": "object",
  "required": [
    "record_type",
    "archive_id",
    "generated_at_utc",
    "html_file_count",
    "total_bytes",
    "link_count",
    "unique_domain_count",
    "attachment_candidate_count",
    "method_claim_candidate_count",
    "numeric_observation_candidate_count",
    "warning_count",
    "raw_logs_committed",
    "message_bodies_committed",
    "usernames_committed",
    "ai_upload_used",
    "live_api_used",
    "scrape_used",
    "output_paths",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "discord_ingestion_summary" },
    "archive_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string" },
    "html_file_count": { "type": "integer", "minimum": 0 },
    "total_bytes": { "type": "integer", "minimum": 0 },
    "link_count": { "type": "integer", "minimum": 0 },
    "unique_domain_count": { "type": "integer", "minimum": 0 },
    "attachment_candidate_count": { "type": "integer", "minimum": 0 },
    "method_claim_candidate_count": { "type": "integer", "minimum": 0 },
    "numeric_observation_candidate_count": { "type": "integer", "minimum": 0 },
    "known_bogus_or_debunked_claim_candidate_count": { "type": "integer", "minimum": 0 },
    "warning_count": { "type": "integer", "minimum": 0 },
    "raw_logs_committed": { "const": false },
    "message_bodies_committed": { "const": false },
    "usernames_committed": { "const": false },
    "ai_upload_used": { "const": false },
    "live_api_used": { "const": false },
    "scrape_used": { "const": false },
    "output_paths": { "type": "object" },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
