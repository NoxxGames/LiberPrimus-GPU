{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/history/discord-full-review-channel-record-v0.schema.json",
  "title": "Discord Full Review Channel Record v0",
  "type": "object",
  "required": [
    "record_type",
    "channel_id",
    "channel_name",
    "source_file_relative_path",
    "source_file_sha256",
    "file_size_bytes",
    "estimated_message_count",
    "part_count",
    "public_link_count",
    "image_reference_count",
    "method_claim_count",
    "numeric_claim_count",
    "visual_claim_count",
    "debunk_count",
    "site_index_relative_path",
    "raw_message_committed"
  ],
  "properties": {
    "record_type": { "const": "discord_full_review_channel_record" },
    "channel_id": { "type": "string", "minLength": 1 },
    "channel_name": { "type": "string", "minLength": 1 },
    "source_file_relative_path": { "type": "string", "minLength": 1 },
    "source_file_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "file_size_bytes": { "type": "integer", "minimum": 0 },
    "estimated_message_count": { "type": "integer", "minimum": 0 },
    "part_count": { "type": "integer", "minimum": 0 },
    "public_link_count": { "type": "integer", "minimum": 0 },
    "image_reference_count": { "type": "integer", "minimum": 0 },
    "method_claim_count": { "type": "integer", "minimum": 0 },
    "numeric_claim_count": { "type": "integer", "minimum": 0 },
    "visual_claim_count": { "type": "integer", "minimum": 0 },
    "debunk_count": { "type": "integer", "minimum": 0 },
    "site_index_relative_path": { "type": "string" },
    "raw_message_committed": { "const": false },
    "username_committed": { "const": false },
    "user_id_committed": { "const": false },
    "message_id_committed": { "const": false },
    "private_url_committed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
