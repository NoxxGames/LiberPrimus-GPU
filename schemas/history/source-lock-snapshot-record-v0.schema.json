{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/history/source-lock-snapshot-record-v0.schema.json",
  "title": "Source Lock Snapshot Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "snapshot_record_id",
    "source_url",
    "canonical_url",
    "source_class",
    "retrieval_status",
    "snapshot_policy",
    "lock_status",
    "licence_or_copyright_note",
    "raw_private_data_committed",
    "binary_committed",
    "image_committed",
    "audio_committed",
    "font_committed",
    "archive_committed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "source_lock_snapshot_record" },
    "snapshot_record_id": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "minLength": 1 },
    "canonical_url": { "type": "string", "minLength": 1 },
    "source_class": {
      "enum": [
        "github_repository",
        "github_tree",
        "github_blob",
        "uncovering_cicada_page",
        "archive_reference",
        "tool_reference",
        "artifact_metadata",
        "historical_reference",
        "rejected_or_noisy"
      ]
    },
    "retrieval_status": {
      "enum": [
        "fetched",
        "metadata_only",
        "network_disabled",
        "fetch_failed",
        "not_fetched_binary_policy",
        "duplicate",
        "rejected"
      ]
    },
    "snapshot_policy": {
      "enum": [
        "metadata_only",
        "ignored_local_snapshot",
        "committed_small_text_snapshot",
        "commit_addressed_reference",
        "archive_reference_only",
        "deferred_manual_review",
        "rejected_unsafe_or_noisy"
      ]
    },
    "lock_status": {
      "enum": [
        "source_locked",
        "metadata_locked",
        "snapshot_cached_ignored",
        "commit_address_locked",
        "deferred_requires_manual_review",
        "rejected_unsafe",
        "duplicate_existing_lock",
        "fetch_failed"
      ]
    },
    "retrieval_timestamp_utc": { "type": "string" },
    "http_status": { "type": ["integer", "null"] },
    "content_type": { "type": ["string", "null"] },
    "content_length": { "type": ["integer", "null"], "minimum": 0 },
    "content_sha256": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    },
    "github_commit_sha": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      ]
    },
    "github_blob_sha": { "type": ["string", "null"] },
    "committed_snapshot": { "type": "boolean" },
    "committed_snapshot_path": { "type": ["string", "null"] },
    "licence_or_copyright_note": { "type": "string", "minLength": 1 },
    "raw_private_data_committed": { "const": false },
    "binary_committed": { "const": false },
    "image_committed": { "const": false },
    "audio_committed": { "const": false },
    "font_committed": { "const": false },
    "archive_committed": { "const": false },
    "solve_claim": { "const": false }
  },
  "allOf": [
    {
      "if": {
        "properties": { "retrieval_status": { "const": "fetched" } },
        "required": ["retrieval_status"]
      },
      "then": {
        "required": ["content_sha256"]
      }
    },
    {
      "if": {
        "properties": { "committed_snapshot": { "const": true } },
        "required": ["committed_snapshot"]
      },
      "then": {
        "properties": {
          "snapshot_policy": { "const": "committed_small_text_snapshot" }
        },
        "required": ["committed_snapshot_path"]
      }
    }
  ]
}
