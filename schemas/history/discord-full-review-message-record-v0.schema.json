{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/history/discord-full-review-message-record-v0.schema.json",
  "title": "Discord Full Review Message Record v0",
  "type": "object",
  "required": [
    "record_type",
    "message_ref",
    "channel_id",
    "approximate_timestamp",
    "redacted_text",
    "public_links",
    "image_refs",
    "attachment_refs",
    "method_keywords",
    "numeric_values",
    "visual_keywords",
    "debunk_keywords",
    "raw_message_committed",
    "username_committed",
    "private_url_committed"
  ],
  "properties": {
    "record_type": { "const": "discord_full_review_message_record" },
    "message_ref": { "type": "string", "minLength": 1 },
    "channel_id": { "type": "string", "minLength": 1 },
    "approximate_timestamp": { "type": ["string", "null"] },
    "redacted_text": { "type": "string" },
    "public_links": { "type": "array", "items": { "type": "string" } },
    "image_refs": { "type": "array", "items": { "type": "object" } },
    "attachment_refs": { "type": "array", "items": { "type": "object" } },
    "method_keywords": { "type": "array", "items": { "type": "string" } },
    "numeric_values": { "type": "array", "items": { "type": "integer" } },
    "visual_keywords": { "type": "array", "items": { "type": "string" } },
    "debunk_keywords": { "type": "array", "items": { "type": "string" } },
    "raw_message_committed": { "const": false },
    "username_committed": { "const": false },
    "user_id_committed": { "const": false },
    "message_id_committed": { "const": false },
    "private_url_committed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
