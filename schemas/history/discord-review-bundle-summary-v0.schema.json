{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/history/discord-review-bundle-summary-v0.schema.json",
  "title": "Discord Review Bundle Summary v0",
  "type": "object",
  "required": [
    "record_type",
    "bundle_id",
    "generated_at_utc",
    "html_file_count",
    "redacted_message_count",
    "topic_shard_count",
    "review_lead_count",
    "public_link_count",
    "method_claim_count",
    "numeric_observation_count",
    "visual_observation_count",
    "debunk_count",
    "output_paths",
    "raw_logs_committed",
    "raw_message_committed",
    "username_committed",
    "private_url_committed",
    "ai_upload_used",
    "live_api_used",
    "scrape_used",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "discord_review_bundle_summary" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "html_file_count": { "type": "integer", "minimum": 0 },
    "redacted_message_count": { "type": "integer", "minimum": 0 },
    "topic_shard_count": { "type": "integer", "minimum": 0 },
    "review_lead_count": { "type": "integer", "minimum": 0 },
    "public_link_count": { "type": "integer", "minimum": 0 },
    "method_claim_count": { "type": "integer", "minimum": 0 },
    "numeric_observation_count": { "type": "integer", "minimum": 0 },
    "visual_observation_count": { "type": "integer", "minimum": 0 },
    "debunk_count": { "type": "integer", "minimum": 0 },
    "output_paths": { "type": "object" },
    "raw_logs_committed": { "const": false },
    "raw_message_committed": { "const": false },
    "username_committed": { "const": false },
    "private_url_committed": { "const": false },
    "ai_upload_used": { "const": false },
    "live_api_used": { "const": false },
    "scrape_used": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
