{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus.local/schemas/history/source-delta-audit-record-v0.schema.json",
  "title": "Stage 4E source delta audit record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "audit_id",
    "source_id",
    "repo_url",
    "remote_head",
    "path_count",
    "source_class",
    "recommended_action",
    "raw_file_committed",
    "binary_committed",
    "font_committed",
    "trusted_as_canonical",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "source_delta_audit_record" },
    "audit_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "repo_url": { "type": "string", "minLength": 1 },
    "remote_head": { "type": ["string", "null"] },
    "path_count": { "type": "integer", "minimum": 0 },
    "category_counts": { "type": "object" },
    "selected_path_candidates": { "type": "array" },
    "source_class": { "type": "string", "minLength": 1 },
    "recommended_action": { "type": "string", "minLength": 1 },
    "raw_file_committed": { "const": false },
    "binary_committed": { "const": false },
    "font_committed": { "const": false },
    "trusted_as_canonical": { "const": false },
    "solve_claim": { "const": false }
  }
}
