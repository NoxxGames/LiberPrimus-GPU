{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/history/source-copyright-policy-record-v0.schema.json",
  "title": "Source Copyright Policy Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "copyright_record_id",
    "snapshot_record_id",
    "source_url",
    "licence_or_copyright_note",
    "committed_snapshot_allowed",
    "raw_private_data_committed",
    "binary_committed",
    "image_committed",
    "audio_committed",
    "font_committed",
    "archive_committed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "source_copyright_policy_record" },
    "copyright_record_id": { "type": "string", "minLength": 1 },
    "snapshot_record_id": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "minLength": 1 },
    "licence_or_copyright_note": { "type": "string", "minLength": 1 },
    "committed_snapshot_allowed": { "type": "boolean" },
    "committed_snapshot_reason": { "type": "string" },
    "raw_private_data_committed": { "const": false },
    "binary_committed": { "const": false },
    "image_committed": { "const": false },
    "audio_committed": { "const": false },
    "font_committed": { "const": false },
    "archive_committed": { "const": false },
    "solve_claim": { "const": false }
  }
}
