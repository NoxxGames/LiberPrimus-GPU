{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/history/source-lock-record-v0.schema.json",
  "title": "Source Lock Record v0",
  "type": "object",
  "required": [
    "record_type",
    "source_id",
    "local_path",
    "relative_path",
    "file_name",
    "file_size_bytes",
    "sha256",
    "media_type",
    "created_at_utc",
    "source_class",
    "trusted_as_canonical",
    "review_status",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "source_lock_record" },
    "source_id": { "type": "string", "minLength": 1 },
    "local_path": { "type": "string", "minLength": 1 },
    "relative_path": { "type": "string", "minLength": 1 },
    "file_name": { "type": "string", "minLength": 1 },
    "file_size_bytes": { "type": "integer", "minimum": 0 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "media_type": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string", "minLength": 1 },
    "source_class": {
      "enum": [
        "primary_signed",
        "strong_community_technical",
        "secondary_archive",
        "reference_only_tooling",
        "archived_claim",
        "speculative_observation",
        "negative_control_material"
      ]
    },
    "trusted_as_canonical": { "const": false },
    "review_status": {
      "enum": [
        "unreviewed",
        "machine_checked",
        "human_review_required",
        "accepted_as_observation",
        "rejected"
      ]
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
