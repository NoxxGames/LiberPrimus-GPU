{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/image-symmetry-record-v0.schema.json",
  "title": "Image Symmetry Record v0",
  "type": "object",
  "required": [
    "record_type",
    "image_id",
    "horizontal_mirror_difference",
    "vertical_mirror_difference",
    "rotational_180_difference",
    "symmetry_rank_fields",
    "trusted_as_canonical",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "image_symmetry_record" },
    "image_id": { "type": "string", "minLength": 1 },
    "horizontal_mirror_difference": { "type": "number", "minimum": 0, "maximum": 1 },
    "vertical_mirror_difference": { "type": "number", "minimum": 0, "maximum": 1 },
    "rotational_180_difference": { "type": "number", "minimum": 0, "maximum": 1 },
    "diagonal_difference": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "symmetry_rank_fields": {
      "type": "array",
      "items": { "enum": ["horizontal_mirror_difference", "vertical_mirror_difference", "rotational_180_difference", "diagonal_difference"] },
      "minItems": 1
    },
    "analysis_width": { "type": "integer", "minimum": 1 },
    "analysis_height": { "type": "integer", "minimum": 1 },
    "trusted_as_canonical": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": false
}
