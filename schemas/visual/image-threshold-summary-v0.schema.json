{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/image-threshold-summary-v0.schema.json",
  "title": "Image Threshold Summary v0",
  "type": "object",
  "required": [
    "record_type",
    "image_id",
    "threshold",
    "foreground_ratio",
    "background_ratio",
    "component_count",
    "largest_component_area_ratio",
    "trusted_as_canonical",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "image_threshold_summary" },
    "image_id": { "type": "string", "minLength": 1 },
    "threshold": { "enum": [32, 64, 96, 128, 160, 192, 224] },
    "foreground_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "background_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "component_count": { "type": "integer", "minimum": 0 },
    "largest_component_area_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "component_analysis_width": { "type": "integer", "minimum": 1 },
    "component_analysis_height": { "type": "integer", "minimum": 1 },
    "component_connectivity": { "enum": ["4-connected"] },
    "trusted_as_canonical": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": false
}
