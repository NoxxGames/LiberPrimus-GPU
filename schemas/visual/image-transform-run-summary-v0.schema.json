{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/image-transform-run-summary-v0.schema.json",
  "title": "Image Transform Run Summary v0",
  "type": "object",
  "required": [
    "record_type",
    "run_id",
    "generated_at_utc",
    "image_count",
    "transform_count",
    "derived_image_count",
    "contact_sheet_count",
    "visual_candidate_count",
    "output_paths",
    "warnings",
    "trusted_as_canonical",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "image_transform_run_summary" },
    "run_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "image_count": { "type": "integer", "minimum": 0 },
    "transform_count": { "type": "integer", "minimum": 0 },
    "derived_image_count": { "type": "integer", "minimum": 0 },
    "contact_sheet_count": { "type": "integer", "minimum": 0 },
    "visual_candidate_count": { "type": "integer", "minimum": 0 },
    "output_paths": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "trusted_as_canonical": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
