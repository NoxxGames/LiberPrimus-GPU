{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus.local/schemas/visual/image-compression-artifact-observation-v0.schema.json",
  "title": "Stage 4E image compression artifact observation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "observation_id",
    "artifact_type",
    "review_status",
    "future_tests",
    "negative_controls",
    "usable_as_experiment_seed",
    "trusted_as_canonical",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "image_compression_artifact_observation" },
    "observation_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1 },
    "review_status": { "type": "string", "minLength": 1 },
    "future_tests": { "type": "array", "minItems": 1 },
    "negative_controls": { "type": "array", "minItems": 1 },
    "usable_as_experiment_seed": { "const": false },
    "trusted_as_canonical": { "const": false },
    "solve_claim": { "const": false }
  }
}
