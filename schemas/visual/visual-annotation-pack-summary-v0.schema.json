{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/visual-annotation-pack-summary-v0.schema.json",
  "title": "Visual Annotation Pack Summary v0",
  "type": "object",
  "required": [
    "record_type",
    "summary_id",
    "stage",
    "task_count",
    "cuneiform_task_count",
    "dot_task_count",
    "delimiter_task_count",
    "negative_control_task_count",
    "unresolved_page_reference_count",
    "generated_site_path",
    "generated_template_count",
    "trusted_as_canonical",
    "usable_as_experiment_seed",
    "solve_claim",
    "raw_outputs_committed",
    "generated_outputs_committed",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "visual_annotation_pack_summary" },
    "summary_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "stage-4c" },
    "task_count": { "type": "integer", "minimum": 0 },
    "cuneiform_task_count": { "type": "integer", "minimum": 0 },
    "dot_task_count": { "type": "integer", "minimum": 0 },
    "delimiter_task_count": { "type": "integer", "minimum": 0 },
    "negative_control_task_count": { "type": "integer", "minimum": 0 },
    "unresolved_page_reference_count": { "type": "integer", "minimum": 0 },
    "generated_site_path": { "type": "string", "minLength": 1 },
    "generated_template_count": { "type": "integer", "minimum": 0 },
    "trusted_as_canonical": { "const": false },
    "usable_as_experiment_seed": { "const": false },
    "solve_claim": { "const": false },
    "raw_outputs_committed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
