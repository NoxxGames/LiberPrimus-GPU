{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/delimiter-annotation-v0.schema.json",
  "title": "Delimiter Annotation v0",
  "type": "object",
  "required": [
    "record_type",
    "task_id",
    "source_observation_id",
    "page_refs",
    "delimiter_type",
    "orientation",
    "handedness",
    "location_reference",
    "reset_boundary_hypothesis",
    "ambiguity_notes",
    "annotation_status",
    "review_status",
    "coordinate_system",
    "trusted_as_canonical",
    "usable_as_experiment_seed",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "delimiter_annotation" },
    "task_id": { "type": "string", "minLength": 1 },
    "source_observation_id": { "type": "string", "minLength": 1 },
    "page_refs": { "type": "array", "items": { "type": "string" } },
    "delimiter_type": { "type": "string", "minLength": 1 },
    "orientation": { "type": "string", "minLength": 1 },
    "handedness": { "type": "string", "minLength": 1 },
    "location_reference": { "type": "string", "minLength": 1 },
    "reset_boundary_hypothesis": { "const": false },
    "ambiguity_notes": { "type": "string", "minLength": 1 },
    "annotation_status": {
      "enum": [
        "pending",
        "needs_human_coordinates",
        "human_review_required",
        "annotated",
        "rejected",
        "superseded"
      ]
    },
    "review_status": { "type": "string", "minLength": 1 },
    "coordinate_system": {
      "enum": ["pixel_absolute", "normalized_0_1", "unknown_pending_annotation"]
    },
    "trusted_as_canonical": { "const": false },
    "usable_as_experiment_seed": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
