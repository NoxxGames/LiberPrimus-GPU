{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/visual-feature-candidate-v0.schema.json",
  "title": "Visual Feature Candidate v0",
  "type": "object",
  "required": [
    "record_type",
    "image_id",
    "feature_id",
    "feature_type",
    "feature_score",
    "evidence_fields",
    "review_status",
    "usable_as_experiment_seed",
    "trusted_as_canonical",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "visual_feature_candidate" },
    "image_id": { "type": "string", "minLength": 1 },
    "feature_id": { "type": "string", "minLength": 1 },
    "feature_type": {
      "enum": [
        "high_symmetry_candidate",
        "high_asymmetry_candidate",
        "sparse_dot_like_candidate",
        "dense_text_like_candidate",
        "large_black_component_candidate",
        "border_marker_candidate",
        "low_bitplane_anomaly_candidate",
        "prime_dimension_candidate",
        "blank_or_near_blank_candidate",
        "high_noise_candidate"
      ]
    },
    "feature_score": { "type": "number" },
    "evidence_fields": { "type": "object" },
    "review_status": { "enum": ["human_review_required", "machine_checked", "unreviewed"] },
    "usable_as_experiment_seed": { "const": false },
    "trusted_as_canonical": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
