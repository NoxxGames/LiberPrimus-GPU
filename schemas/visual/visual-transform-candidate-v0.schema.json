{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/visual-transform-candidate-v0.schema.json",
  "title": "Visual Transform Candidate v0",
  "type": "object",
  "required": [
    "record_type",
    "candidate_id",
    "image_id",
    "feature_type",
    "transform_names",
    "feature_score",
    "evidence_fields",
    "review_status",
    "output_references",
    "trusted_as_canonical",
    "usable_as_experiment_seed",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "visual_transform_candidate" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "image_id": { "type": "string", "minLength": 1 },
    "feature_type": {
      "enum": [
        "hidden_low_bitplane_candidate",
        "high_half_mirror_difference_candidate",
        "high_rotational_symmetry_candidate",
        "sparse_dot_like_candidate",
        "dense_rune_text_candidate",
        "border_marker_candidate",
        "large_component_candidate",
        "high_edge_density_candidate",
        "potential_symbol_cluster_candidate",
        "high_noise_candidate"
      ]
    },
    "transform_names": { "type": "array", "items": { "type": "string" } },
    "feature_score": { "type": "number" },
    "evidence_fields": { "type": "object" },
    "review_status": { "enum": ["human_review_required", "machine_checked", "rejected"] },
    "output_references": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^experiments/results/image-transforms/stage3p/"
      }
    },
    "trusted_as_canonical": { "const": false },
    "usable_as_experiment_seed": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
