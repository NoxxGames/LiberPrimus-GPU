{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/visual/image-compression-preflight-record-v0.schema.json",
  "title": "Image Compression Preflight Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "compression_record_id",
    "image_id",
    "relative_path",
    "sha256",
    "compression_metric_status",
    "metric_only",
    "raw_image_committed",
    "generated_image_committed",
    "solve_claim",
    "trusted_as_canonical",
    "usable_as_experiment_seed",
    "image_interpretation_claim"
  ],
  "properties": {
    "record_type": { "const": "image_compression_preflight_record" },
    "compression_record_id": { "type": "string", "minLength": 1 },
    "image_id": { "type": "string", "minLength": 1 },
    "relative_path": { "type": "string", "minLength": 1 },
    "file_name": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "compression_metric_status": { "enum": ["computed", "unsupported_format", "read_failed"] },
    "metric_only": { "const": true },
    "blockiness_proxy": { "type": ["number", "null"] },
    "jpeg_grid_artifact_score": { "type": ["number", "null"] },
    "jpeg_like_metric_flag": { "type": "boolean" },
    "raw_image_committed": { "const": false },
    "generated_image_committed": { "const": false },
    "solve_claim": { "const": false },
    "trusted_as_canonical": { "const": false },
    "usable_as_experiment_seed": { "const": false },
    "image_interpretation_claim": { "const": false }
  }
}
