{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/dot-pattern-annotation-v0.schema.json",
  "title": "Dot Pattern Annotation v0",
  "type": "object",
  "required": [
    "record_type",
    "task_id",
    "source_observation_id",
    "page_refs",
    "dot_count",
    "filled_count",
    "hollow_count",
    "ordering_policy",
    "polarity_policy",
    "possible_readings",
    "claimed_readings",
    "ambiguity_notes",
    "annotation_status",
    "review_status",
    "coordinate_system",
    "trusted_as_canonical",
    "usable_as_experiment_seed",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "dot_pattern_annotation" },
    "task_id": { "type": "string", "minLength": 1 },
    "source_observation_id": { "type": "string", "minLength": 1 },
    "page_refs": { "type": "array", "items": { "type": "string" } },
    "dot_count": { "type": ["integer", "null"], "minimum": 0 },
    "filled_count": { "type": ["integer", "null"], "minimum": 0 },
    "hollow_count": { "type": ["integer", "null"], "minimum": 0 },
    "ordering_policy": { "type": "string", "minLength": 1 },
    "polarity_policy": { "type": "string", "minLength": 1 },
    "possible_readings": { "type": "array" },
    "claimed_readings": { "type": "array" },
    "ambiguity_notes": { "type": "string", "minLength": 1 },
    "annotation_status": {
      "enum": [
        "pending",
        "needs_human_coordinates",
        "human_review_required",
        "annotated",
        "rejected",
        "superseded"
      ]
    },
    "review_status": { "type": "string", "minLength": 1 },
    "coordinate_system": {
      "enum": ["pixel_absolute", "normalized_0_1", "unknown_pending_annotation"]
    },
    "trusted_as_canonical": { "const": false },
    "usable_as_experiment_seed": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
