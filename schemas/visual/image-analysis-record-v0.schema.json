{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/image-analysis-record-v0.schema.json",
  "title": "Image Analysis Record v0",
  "type": "object",
  "required": [
    "record_type",
    "image_id",
    "source_id",
    "image_sha256",
    "relative_path",
    "file_name",
    "width",
    "height",
    "image_format",
    "color_mode",
    "grayscale_min",
    "grayscale_max",
    "grayscale_mean",
    "grayscale_stddev",
    "black_pixel_ratio",
    "white_pixel_ratio",
    "midtone_ratio",
    "trusted_as_canonical",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "image_analysis_record" },
    "image_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "image_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "relative_path": { "type": "string", "minLength": 1 },
    "file_name": { "type": "string", "minLength": 1 },
    "file_size_bytes": { "type": "integer", "minimum": 0 },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "image_format": { "type": "string", "minLength": 1 },
    "color_mode": { "type": "string", "minLength": 1 },
    "width_is_prime": { "type": "boolean" },
    "height_is_prime": { "type": "boolean" },
    "both_dimensions_prime": { "type": "boolean" },
    "grayscale_min": { "type": "integer", "minimum": 0, "maximum": 255 },
    "grayscale_max": { "type": "integer", "minimum": 0, "maximum": 255 },
    "grayscale_mean": { "type": "number", "minimum": 0, "maximum": 255 },
    "grayscale_median": { "type": "number", "minimum": 0, "maximum": 255 },
    "grayscale_stddev": { "type": "number", "minimum": 0 },
    "black_pixel_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "white_pixel_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "midtone_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "channel_statistics": { "type": "object" },
    "border_statistics": { "type": "object" },
    "foreground_bbox": {
      "type": ["array", "null"],
      "items": { "type": "integer" },
      "minItems": 4,
      "maxItems": 4
    },
    "average_hash_8x8": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
    "trusted_as_canonical": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
