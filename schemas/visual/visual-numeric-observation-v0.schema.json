{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/visual-numeric-observation-v0.schema.json",
  "title": "Visual Numeric Observation v0",
  "type": "object",
  "required": [
    "record_type",
    "observation_id",
    "source_id",
    "image_id",
    "observation_type",
    "description",
    "confidence",
    "review_status",
    "candidate_readings",
    "derived_values",
    "evidence_notes",
    "ambiguity_notes",
    "trusted_as_canonical",
    "usable_as_experiment_seed",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "visual_numeric_observation" },
    "observation_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "image_id": { "type": "string", "minLength": 1 },
    "observation_type": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "confidence": { "enum": ["high", "medium", "low", "review_required", "rejected"] },
    "review_status": {
      "enum": [
        "unreviewed",
        "machine_checked",
        "human_review_required",
        "accepted_as_observation",
        "rejected"
      ]
    },
    "candidate_readings": {
      "type": "array",
      "items": { "$ref": "visual-observation-reading-v0.schema.json" }
    },
    "derived_values": { "type": "object" },
    "evidence_notes": { "type": "string" },
    "ambiguity_notes": { "type": "string" },
    "trusted_as_canonical": { "const": false },
    "usable_as_experiment_seed": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
