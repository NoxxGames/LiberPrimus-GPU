{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/visual/cuneiform-reading-candidate-v0.schema.json",
  "title": "Cuneiform Reading Candidate v0",
  "type": "object",
  "required": [
    "record_type",
    "candidate_id",
    "task_id",
    "source_observation_id",
    "page_refs",
    "proposed_reading",
    "reading_basis",
    "ambiguity_notes",
    "alternative_readings",
    "derived_values",
    "annotation_status",
    "review_status",
    "coordinate_system",
    "trusted_as_canonical",
    "usable_as_experiment_seed",
    "solve_claim",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "cuneiform_reading_candidate" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "source_observation_id": { "type": "string", "minLength": 1 },
    "page_refs": { "type": "array", "items": { "type": "string" } },
    "proposed_reading": { "type": "array", "items": { "type": ["integer", "string"] } },
    "reading_basis": { "type": "string", "minLength": 1 },
    "ambiguity_notes": { "type": "string", "minLength": 1 },
    "alternative_readings": { "type": "array" },
    "derived_values": { "type": "object" },
    "annotation_status": {
      "enum": [
        "pending",
        "needs_human_coordinates",
        "human_review_required",
        "annotated",
        "rejected",
        "superseded"
      ]
    },
    "review_status": { "type": "string", "minLength": 1 },
    "coordinate_system": {
      "enum": ["pixel_absolute", "normalized_0_1", "unknown_pending_annotation"]
    },
    "trusted_as_canonical": { "const": false },
    "usable_as_experiment_seed": { "const": false },
    "solve_claim": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
