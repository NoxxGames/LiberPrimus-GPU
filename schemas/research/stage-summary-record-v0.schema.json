{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/research/stage-summary-record-v0.schema.json",
  "title": "Stage Summary Record v0",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "title",
    "status",
    "category",
    "summary",
    "key_outputs",
    "result_status",
    "solve_claim",
    "cuda_used",
    "raw_outputs_committed",
    "generated_outputs_committed",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "stage_summary_record" },
    "stage_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "key_outputs": { "type": "array", "items": { "type": "string" } },
    "result_status": { "type": "string", "minLength": 1 },
    "solve_claim": { "const": false },
    "cuda_used": { "type": "boolean" },
    "raw_outputs_committed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
