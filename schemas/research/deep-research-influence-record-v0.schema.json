{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/research/deep-research-influence-record-v0.schema.json",
  "title": "Deep Research Influence Record v0",
  "type": "object",
  "required": [
    "record_type",
    "report_id",
    "report_title",
    "influence_summary",
    "direction_changes",
    "adopted_recommendations",
    "rejected_recommendations",
    "affected_stages",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "deep_research_influence_record" },
    "report_id": { "type": "string", "minLength": 1 },
    "report_title": { "type": "string", "minLength": 1 },
    "influence_summary": { "type": "string", "minLength": 1 },
    "direction_changes": { "type": "array", "items": { "type": "string" } },
    "adopted_recommendations": { "type": "array", "items": { "type": "string" } },
    "rejected_recommendations": { "type": "array", "items": { "type": "string" } },
    "affected_stages": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
