{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/results/result-store-unification-summary-v0.schema.json",
  "title": "result-store-unification-summary-v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "status",
    "source_inventory_records",
    "committed_summaries_loaded",
    "optional_generated_outputs_present",
    "optional_generated_outputs_missing",
    "unified_result_records",
    "unified_score_summary_records",
    "method_status_joins",
    "cross_stage_report_written",
    "score_summary_contract",
    "result_store_contract",
    "no_solve_claim",
    "cuda_used",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "new_experiment_executed",
    "new_scorer_added"
  ],
  "properties": {
    "record_type": { "const": "stage4p_result_store_score_summary_unification_summary" },
    "stage_id": { "const": "stage-4p" },
    "status": { "const": "complete" },
    "source_inventory_records": { "type": "integer", "minimum": 0 },
    "committed_summaries_loaded": { "type": "integer", "minimum": 0 },
    "optional_generated_outputs_present": { "type": "integer", "minimum": 0 },
    "optional_generated_outputs_missing": { "type": "integer", "minimum": 0 },
    "unified_result_records": { "type": "integer", "minimum": 0 },
    "unified_score_summary_records": { "type": "integer", "minimum": 0 },
    "method_status_joins": { "type": "integer", "minimum": 0 },
    "cross_stage_report_written": { "type": "boolean" },
    "score_summary_contract": { "const": "stage4i" },
    "result_store_contract": { "const": "stage4p" },
    "no_solve_claim": { "const": true },
    "cuda_used": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "new_experiment_executed": { "const": false },
    "new_scorer_added": { "const": false }
  }
}
