{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/results/cross-stage-comparison-report-v0.schema.json",
  "title": "cross-stage-comparison-report-v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "total_source_inventory_records",
    "committed_summaries_loaded",
    "optional_generated_outputs_present",
    "optional_generated_outputs_missing",
    "unified_result_records",
    "unified_score_summary_records",
    "method_status_joins",
    "score_interpretation",
    "no_solve_claim",
    "solve_claim",
    "cuda_used",
    "generated_outputs_committed",
    "raw_data_processed",
    "new_experiment_executed",
    "new_scorer_added"
  ],
  "properties": {
    "record_type": { "const": "cross_stage_comparison_report" },
    "stage_id": { "const": "stage-4p" },
    "total_source_inventory_records": { "type": "integer", "minimum": 0 },
    "committed_summaries_loaded": { "type": "integer", "minimum": 0 },
    "optional_generated_outputs_present": { "type": "integer", "minimum": 0 },
    "optional_generated_outputs_missing": { "type": "integer", "minimum": 0 },
    "unified_result_records": { "type": "integer", "minimum": 0 },
    "unified_score_summary_records": { "type": "integer", "minimum": 0 },
    "method_status_joins": { "type": "integer", "minimum": 0 },
    "stages_represented": { "type": "array", "items": { "type": "string" } },
    "method_families_represented": { "type": "array", "items": { "type": "string" } },
    "confidence_label_counts": { "type": "object" },
    "method_status_counts": { "type": "object" },
    "retirement_status_counts": { "type": "object" },
    "records_with_output_hashes": { "type": "integer", "minimum": 0 },
    "records_with_parity_expectations": { "type": "integer", "minimum": 0 },
    "records_without_score_summaries": { "type": "integer", "minimum": 0 },
    "records_skipped_due_raw_required_input": { "type": "integer", "minimum": 0 },
    "records_skipped_due_unknown_schema": { "type": "integer", "minimum": 0 },
    "score_interpretation": { "const": "triage_only" },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false },
    "cuda_used": { "const": false },
    "generated_outputs_committed": { "const": false },
    "raw_data_processed": { "const": false },
    "new_experiment_executed": { "const": false },
    "new_scorer_added": { "const": false }
  }
}
