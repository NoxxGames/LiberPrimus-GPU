{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/results/experiment-run-summary-v0.schema.json",
  "title": "Experiment Run Summary v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "summary_id",
    "generated_at_utc",
    "run_count",
    "pass_count",
    "fail_count",
    "partial_count",
    "pending_count",
    "skipped_count",
    "error_count",
    "run_kinds",
    "canonical_corpus_active_any",
    "search_performed_any",
    "scoring_used_any",
    "cuda_used_any",
    "generated_artifact_count",
    "sqlite_database_path",
    "jsonl_path",
    "warnings",
    "trusted_as_canonical"
  ],
  "properties": {
    "record_type": { "const": "experiment_run_summary" },
    "summary_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string" },
    "run_count": { "type": "integer", "minimum": 0 },
    "pass_count": { "type": "integer", "minimum": 0 },
    "fail_count": { "type": "integer", "minimum": 0 },
    "partial_count": { "type": "integer", "minimum": 0 },
    "pending_count": { "type": "integer", "minimum": 0 },
    "skipped_count": { "type": "integer", "minimum": 0 },
    "error_count": { "type": "integer", "minimum": 0 },
    "run_kinds": { "type": "array", "items": { "type": "string" } },
    "canonical_corpus_active_any": { "const": false },
    "search_performed_any": { "const": false },
    "scoring_used_any": { "const": false },
    "cuda_used_any": { "const": false },
    "generated_artifact_count": { "type": "integer", "minimum": 0 },
    "sqlite_database_path": { "type": "string" },
    "jsonl_path": { "type": "string" },
    "warnings": { "type": "array" },
    "trusted_as_canonical": { "const": false }
  }
}
