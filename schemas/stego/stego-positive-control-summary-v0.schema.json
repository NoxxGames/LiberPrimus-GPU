{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/stego/stego-positive-control-summary-v0.schema.json",
  "title": "Stego Positive-Control Summary v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage",
    "outguess_readiness_records_count",
    "audio_readiness_records_count",
    "fixture_cache_records_count",
    "expected_output_records_count",
    "toolchain_readiness_records_count",
    "historical_fixtures_ready_count",
    "historical_fixtures_blocked_count",
    "synthetic_controls_ready_count",
    "raw_file_committed",
    "binary_committed",
    "image_committed",
    "audio_committed",
    "font_committed",
    "archive_committed",
    "extracted_payload_committed",
    "solve_claim",
    "execution_performed",
    "tool_executed"
  ],
  "properties": {
    "record_type": { "const": "stego_positive_control_summary" },
    "stage": { "const": "stage4n" },
    "outguess_readiness_records_count": { "type": "integer", "minimum": 0 },
    "audio_readiness_records_count": { "type": "integer", "minimum": 0 },
    "fixture_cache_records_count": { "type": "integer", "minimum": 0 },
    "expected_output_records_count": { "type": "integer", "minimum": 0 },
    "toolchain_readiness_records_count": { "type": "integer", "minimum": 0 },
    "historical_fixtures_ready_count": { "type": "integer", "minimum": 0 },
    "historical_fixtures_blocked_count": { "type": "integer", "minimum": 0 },
    "synthetic_controls_ready_count": { "type": "integer", "minimum": 0 },
    "raw_file_committed": { "const": false },
    "binary_committed": { "const": false },
    "image_committed": { "const": false },
    "audio_committed": { "const": false },
    "font_committed": { "const": false },
    "archive_committed": { "const": false },
    "extracted_payload_committed": { "const": false },
    "solve_claim": { "const": false },
    "execution_performed": { "const": false },
    "tool_executed": { "const": false }
  }
}
