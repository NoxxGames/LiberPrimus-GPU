{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/stego/audio-positive-control-readiness-v0.schema.json",
  "title": "Audio Positive-Control Readiness v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "readiness_id",
    "source_record_id",
    "fixture_category",
    "ready_state",
    "expected_output_required",
    "raw_file_committed",
    "binary_committed",
    "image_committed",
    "audio_committed",
    "font_committed",
    "archive_committed",
    "extracted_payload_committed",
    "solve_claim",
    "execution_performed",
    "tool_executed"
  ],
  "properties": {
    "record_type": { "const": "audio_positive_control_readiness" },
    "readiness_id": { "type": "string", "minLength": 1 },
    "source_record_id": { "type": "string", "minLength": 1 },
    "fixture_category": {
      "enum": [
        "openpuff_interconnectedness_candidate",
        "mp3_instar_candidate",
        "audio_hexdump_candidate",
        "outguess_reference_only",
        "synthetic_positive_control",
        "synthetic_negative_control",
        "rejected_unsafe_or_out_of_scope"
      ]
    },
    "ready_state": {
      "enum": [
        "ready_with_cached_asset_and_expected_output",
        "cached_asset_missing_expected_output",
        "source_only_missing_asset",
        "source_only_missing_expected_output",
        "blocked_tool_unavailable",
        "blocked_expected_output_unknown",
        "blocked_asset_not_cached",
        "blocked_manual_source_review",
        "reference_only",
        "synthetic_ready",
        "rejected_unsafe_or_out_of_scope"
      ]
    },
    "expected_output_required": { "type": "boolean" },
    "expected_output_hash": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    },
    "synthetic": { "type": "boolean" },
    "raw_file_committed": { "const": false },
    "binary_committed": { "const": false },
    "image_committed": { "const": false },
    "audio_committed": { "const": false },
    "font_committed": { "const": false },
    "archive_committed": { "const": false },
    "extracted_payload_committed": { "const": false },
    "solve_claim": { "const": false },
    "execution_performed": { "const": false },
    "tool_executed": { "const": false }
  }
}
