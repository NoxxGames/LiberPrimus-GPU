{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/stego/stego-fixture-cache-record-v0.schema.json",
  "title": "Stego Fixture Cache Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "cache_record_id",
    "source_record_id",
    "cache_policy",
    "local_availability",
    "raw_file_committed",
    "binary_committed",
    "image_committed",
    "audio_committed",
    "font_committed",
    "archive_committed",
    "extracted_payload_committed",
    "solve_claim",
    "execution_performed",
    "tool_executed"
  ],
  "properties": {
    "record_type": { "const": "stego_fixture_cache_record" },
    "cache_record_id": { "type": "string", "minLength": 1 },
    "source_record_id": { "type": "string", "minLength": 1 },
    "cache_policy": {
      "enum": [
        "source_only",
        "deferred",
        "cache_candidate",
        "cached_ignored",
        "synthetic_generated_for_tests",
        "reference_only",
        "rejected_unsafe_or_out_of_scope"
      ]
    },
    "local_availability": {
      "enum": [
        "source_only",
        "deferred",
        "present_ignored_cache",
        "absent",
        "generated_test_only",
        "not_applicable"
      ]
    },
    "sha256": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    },
    "file_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "media_type": { "type": ["string", "null"] },
    "raw_file_committed": { "const": false },
    "binary_committed": { "const": false },
    "image_committed": { "const": false },
    "audio_committed": { "const": false },
    "font_committed": { "const": false },
    "archive_committed": { "const": false },
    "extracted_payload_committed": { "const": false },
    "solve_claim": { "const": false },
    "execution_performed": { "const": false },
    "tool_executed": { "const": false }
  }
}
