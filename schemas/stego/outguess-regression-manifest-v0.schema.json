{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/stego/outguess-regression-manifest-v0.schema.json",
  "title": "OutGuess Regression Manifest v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "manifest_id",
    "description",
    "tool_required",
    "allow_missing_tool",
    "allow_missing_assets",
    "cases",
    "expected_case_count_upper_bound",
    "cpu_only",
    "cuda_enabled",
    "no_solve_claim",
    "generated_outputs_committed",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "outguess_regression_manifest" },
    "manifest_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "tool_required": { "type": "boolean" },
    "allow_missing_tool": { "type": "boolean" },
    "allow_missing_assets": { "type": "boolean" },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "artifact_id", "enabled", "expected_role"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "artifact_id": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "expected_role": { "type": "string" }
        }
      }
    },
    "expected_case_count_upper_bound": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "cpu_only": { "const": true },
    "cuda_enabled": { "const": false },
    "no_solve_claim": { "const": true },
    "generated_outputs_committed": { "const": false },
    "notes": { "type": "string" }
  }
}
