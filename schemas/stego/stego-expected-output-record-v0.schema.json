{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/stego/stego-expected-output-record-v0.schema.json",
  "title": "Stego Expected Output Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "expected_output_id",
    "source_record_id",
    "expected_output_status",
    "expected_output_required",
    "synthetic",
    "raw_file_committed",
    "binary_committed",
    "image_committed",
    "audio_committed",
    "font_committed",
    "archive_committed",
    "extracted_payload_committed",
    "solve_claim",
    "execution_performed",
    "tool_executed"
  ],
  "properties": {
    "record_type": { "const": "stego_expected_output_record" },
    "expected_output_id": { "type": "string", "minLength": 1 },
    "source_record_id": { "type": "string", "minLength": 1 },
    "expected_output_status": {
      "enum": [
        "known_hash",
        "known_text_hash",
        "unknown",
        "not_required_reference_only",
        "synthetic_known"
      ]
    },
    "expected_output_required": { "type": "boolean" },
    "expected_payload_sha256": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    },
    "expected_payload_text_sha256": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    },
    "synthetic": { "type": "boolean" },
    "raw_file_committed": { "const": false },
    "binary_committed": { "const": false },
    "image_committed": { "const": false },
    "audio_committed": { "const": false },
    "font_committed": { "const": false },
    "archive_committed": { "const": false },
    "extracted_payload_committed": { "const": false },
    "solve_claim": { "const": false },
    "execution_performed": { "const": false },
    "tool_executed": { "const": false }
  }
}
