{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/stego/outguess-regression-summary-v0.schema.json",
  "title": "OutGuess Regression Summary v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "run_id",
    "generated_at_utc",
    "tool_available",
    "case_count",
    "attempted_count",
    "passed_count",
    "failed_count",
    "skipped_tool_missing_count",
    "skipped_asset_missing_count",
    "extraction_error_count",
    "unexpected_payload_count",
    "output_paths",
    "raw_payloads_committed",
    "solve_claim",
    "cuda_used",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "outguess_regression_summary" },
    "run_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string" },
    "tool_available": { "type": "boolean" },
    "case_count": { "type": "integer", "minimum": 0 },
    "attempted_count": { "type": "integer", "minimum": 0 },
    "passed_count": { "type": "integer", "minimum": 0 },
    "failed_count": { "type": "integer", "minimum": 0 },
    "skipped_tool_missing_count": { "type": "integer", "minimum": 0 },
    "skipped_asset_missing_count": { "type": "integer", "minimum": 0 },
    "extraction_error_count": { "type": "integer", "minimum": 0 },
    "unexpected_payload_count": { "type": "integer", "minimum": 0 },
    "output_paths": { "type": "object" },
    "raw_payloads_committed": { "const": false },
    "solve_claim": { "const": false },
    "cuda_used": { "const": false },
    "notes": { "type": "string" }
  }
}
