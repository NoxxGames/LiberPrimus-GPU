{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/cpu-batch-result-record-v0.schema.json",
  "title": "CPU Batch Result Record v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type",
    "run_id",
    "manifest_id",
    "candidate_id",
    "input_stream_id",
    "transform_family",
    "transform_id",
    "transform_parameters",
    "execution_status",
    "token_count",
    "transformable_token_count",
    "cpu_only",
    "cuda_used",
    "cuda_required",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed"
  ],
  "properties": {
    "record_type": { "const": "cpu_batch_result_record" },
    "run_id": { "type": "string", "minLength": 1 },
    "manifest_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "input_stream_id": { "type": "string", "minLength": 1 },
    "transform_family": { "type": "string", "minLength": 1 },
    "transform_id": { "type": "string", "minLength": 1 },
    "canonical_transform_id": { "type": "string" },
    "transform_parameters": { "type": "object" },
    "execution_status": { "enum": ["executed", "adapter_missing", "error"] },
    "adapter_status": { "type": "string" },
    "token_count": { "type": "integer", "minimum": 0 },
    "transformable_token_count": { "type": "integer", "minimum": 0 },
    "output_text": { "type": ["string", "null"] },
    "output_text_hash": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
    "output_token_hash": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
    "score_summary": { "type": ["object", "null"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false }
  },
  "anyOf": [
    { "required": ["output_text_hash"] },
    { "required": ["output_token_hash"] }
  ]
}
