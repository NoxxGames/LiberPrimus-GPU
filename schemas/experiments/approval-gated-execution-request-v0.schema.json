{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/approval-gated-execution-request-v0.schema.json",
  "title": "approval-gated-execution-request-v0",
  "type": "object",
  "required": [
    "record_type",
    "request_id",
    "request_version",
    "proposal_path",
    "approval_record_path",
    "output_dir",
    "requested_at_utc",
    "requested_by",
    "execution_scope",
    "unsolved_execution_allowed",
    "search_execution_enabled",
    "candidate_generation_enabled",
    "scoring_enabled",
    "cuda_enabled",
    "canonical_corpus_active",
    "page_boundaries_final",
    "trusted_as_canonical",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "approval_gated_execution_request" },
    "request_id": { "type": "string", "minLength": 1 },
    "request_version": { "type": "string", "minLength": 1 },
    "proposal_path": { "type": "string", "minLength": 1 },
    "approval_record_path": { "type": "string", "minLength": 1 },
    "output_dir": { "type": "string", "minLength": 1 },
    "requested_at_utc": { "type": "string", "minLength": 1 },
    "requested_by": { "type": "string", "minLength": 1 },
    "execution_scope": {
      "type": "string",
      "enum": [
        "synthetic_only",
        "solved_fixture_only",
        "synthetic_and_solved_fixture_only",
        "no_op_review_only"
      ]
    },
    "unsolved_execution_allowed": { "const": false },
    "search_execution_enabled": { "const": false },
    "candidate_generation_enabled": { "const": false },
    "scoring_enabled": { "const": false },
    "cuda_enabled": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "trusted_as_canonical": { "const": false },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
