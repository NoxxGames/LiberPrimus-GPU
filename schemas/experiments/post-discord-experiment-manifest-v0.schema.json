{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/experiments/post-discord-experiment-manifest-v0.schema.json",
  "title": "Post Discord Experiment Manifest v0",
  "type": "object",
  "required": [
    "record_type",
    "experiment_id",
    "description",
    "hypothesis",
    "source_basis",
    "candidate_count_cap",
    "execution_enabled",
    "cpu_only",
    "cuda_enabled",
    "cloud_execution",
    "paid_services",
    "generated_outputs_committed",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "required_inputs",
    "controls",
    "stop_conditions",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "post_discord_experiment_manifest" },
    "experiment_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "hypothesis": { "type": "string", "minLength": 1 },
    "source_basis": { "type": "array", "items": { "type": "string" } },
    "candidate_count_cap": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "execution_enabled": { "const": false },
    "cpu_only": { "const": true },
    "cuda_enabled": { "const": false },
    "cloud_execution": { "const": false },
    "paid_services": { "const": false },
    "generated_outputs_committed": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "required_inputs": { "type": "array" },
    "controls": { "type": "array" },
    "stop_conditions": { "type": "array" },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
