{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/cpu-batch-adapter-expansion-summary-v0.schema.json",
  "title": "CPU Batch Adapter Expansion Summary v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "status",
    "solved_fixture_streams_discovered",
    "solved_fixture_streams_executed",
    "skipped_fixture_streams",
    "transform_adapters_supported",
    "transform_adapters_missing_or_deferred",
    "candidates_executed",
    "result_records",
    "parity_expectations_written",
    "scoring_compatible_count",
    "scoring_unavailable_count",
    "cpu_only",
    "cuda_used",
    "cuda_required",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed"
  ],
  "properties": {
    "record_type": { "const": "stage4o_cpu_batch_adapter_expansion_summary" },
    "stage_id": { "const": "stage-4o" },
    "status": { "type": "string", "minLength": 1 },
    "solved_fixture_streams_discovered": { "type": "integer", "minimum": 0 },
    "solved_fixture_streams_executed": { "type": "integer", "minimum": 0 },
    "skipped_fixture_streams": { "type": "integer", "minimum": 0 },
    "transform_adapters_supported": { "type": "integer", "minimum": 0 },
    "transform_adapters_missing_or_deferred": { "type": "integer", "minimum": 0 },
    "candidates_executed": { "type": "integer", "minimum": 0 },
    "result_records": { "type": "integer", "minimum": 0 },
    "parity_expectations_written": { "type": "integer", "minimum": 0 },
    "scoring_compatible_count": { "type": "integer", "minimum": 0 },
    "scoring_unavailable_count": { "type": "integer", "minimum": 0 },
    "cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false }
  }
}
