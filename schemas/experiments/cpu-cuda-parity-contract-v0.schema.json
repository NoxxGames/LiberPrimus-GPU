{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/cpu-cuda-parity-contract-v0.schema.json",
  "title": "CPU/CUDA Parity Contract v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type",
    "parity_contract_version",
    "cpu_reference_package",
    "cuda_implementation_status",
    "required_semantics",
    "required_result_fields",
    "cpu_only",
    "cuda_used",
    "cuda_required",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final"
  ],
  "properties": {
    "record_type": { "const": "cpu_cuda_parity_contract" },
    "parity_contract_version": { "type": "string", "minLength": 1 },
    "cpu_reference_package": { "type": "string", "minLength": 1 },
    "cuda_implementation_status": { "enum": ["deferred", "not_started"] },
    "required_semantics": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_result_fields": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
