{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/liberprimus-gpu/schemas/experiments/exploratory-dry-run-plan-v0.schema.json",
  "title": "exploratory-dry-run-plan-v0",
  "type": "object",
  "required": [
    "record_type",
    "plan_id",
    "manifest_id",
    "manifest_sha256",
    "generated_at_utc",
    "git_commit",
    "dry_run_only",
    "execution_enabled",
    "search_execution_enabled",
    "candidate_generation_enabled",
    "scoring_enabled",
    "cuda_enabled",
    "canonical_corpus_active",
    "page_boundaries_final",
    "trusted_as_canonical",
    "corpus_slice_summary",
    "transform_space_summary",
    "candidate_count_estimate",
    "candidate_count_upper_bound",
    "safety_gate_results",
    "warnings",
    "output_paths",
    "result_store_preview",
    "elapsed_ms"
  ],
  "properties": {
    "record_type": { "const": "exploratory_dry_run_plan" },
    "plan_id": { "type": "string" },
    "manifest_id": { "type": "string" },
    "manifest_sha256": { "type": "string" },
    "generated_at_utc": { "type": "string" },
    "git_commit": { "type": "string" },
    "dry_run_only": { "const": true },
    "execution_enabled": { "const": false },
    "search_execution_enabled": { "const": false },
    "candidate_generation_enabled": { "const": false },
    "scoring_enabled": { "const": false },
    "cuda_enabled": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "trusted_as_canonical": { "const": false },
    "corpus_slice_summary": { "type": "object" },
    "transform_space_summary": { "type": "object" },
    "candidate_count_estimate": { "type": "integer", "minimum": 0 },
    "candidate_count_upper_bound": { "type": "integer", "minimum": 0 },
    "safety_gate_results": {
      "type": "array",
      "items": { "type": "object" }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "output_paths": { "type": "object" },
    "result_store_preview": { "type": "object" },
    "elapsed_ms": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false
}
