{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/bounded-auto-run-result-v0.schema.json",
  "title": "bounded-auto-run-result-v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "item_id",
    "queue_id",
    "policy_id",
    "generated_at_utc",
    "git_commit",
    "execution_performed",
    "candidate_count",
    "output_paths",
    "summary",
    "search_performed",
    "scoring_used",
    "cuda_used",
    "solve_claim_made",
    "canonical_corpus_active",
    "page_boundaries_final",
    "trusted_as_canonical"
  ],
  "properties": {
    "record_type": { "const": "bounded_auto_run_result" },
    "item_id": { "type": "string", "minLength": 1 },
    "queue_id": { "type": "string", "minLength": 1 },
    "policy_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "git_commit": { "type": "string", "minLength": 1 },
    "execution_performed": { "type": "boolean" },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "output_paths": { "type": "object" },
    "summary": { "type": "object" },
    "search_performed": { "type": "boolean" },
    "scoring_used": { "type": "boolean" },
    "cuda_used": { "const": false },
    "solve_claim_made": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "trusted_as_canonical": { "const": false }
  }
}
