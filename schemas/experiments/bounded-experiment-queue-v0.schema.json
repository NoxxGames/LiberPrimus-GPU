{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/bounded-experiment-queue-v0.schema.json",
  "title": "bounded-experiment-queue-v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "queue_id",
    "queue_version",
    "policy_id",
    "items",
    "default_output_dir",
    "canonical_corpus_active",
    "page_boundaries_final",
    "trusted_as_canonical"
  ],
  "properties": {
    "record_type": { "const": "bounded_experiment_queue" },
    "queue_id": { "type": "string", "minLength": 1 },
    "queue_version": { "type": "string", "minLength": 1 },
    "policy_id": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "default_output_dir": { "type": "string", "minLength": 1 },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "trusted_as_canonical": { "const": false }
  }
}
