{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/cpu-batch-run-summary-v0.schema.json",
  "title": "CPU Batch Run Summary v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type",
    "run_id",
    "manifest_id",
    "input_stream_count",
    "candidate_count",
    "executed_candidate_count",
    "adapter_missing_count",
    "result_record_count",
    "scoring_available_count",
    "scoring_unavailable_count",
    "cpu_only",
    "cuda_used",
    "cuda_required",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed"
  ],
  "properties": {
    "record_type": { "const": "cpu_batch_run_summary" },
    "run_id": { "type": "string", "minLength": 1 },
    "manifest_id": { "type": "string", "minLength": 1 },
    "input_stream_count": { "type": "integer", "minimum": 0 },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "executed_candidate_count": { "type": "integer", "minimum": 0 },
    "adapter_missing_count": { "type": "integer", "minimum": 0 },
    "result_record_count": { "type": "integer", "minimum": 0 },
    "scoring_available_count": { "type": "integer", "minimum": 0 },
    "scoring_unavailable_count": { "type": "integer", "minimum": 0 },
    "adapter_coverage": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "cpu_only": { "const": true },
    "cuda_used": { "const": false },
    "cuda_required": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false }
  }
}
