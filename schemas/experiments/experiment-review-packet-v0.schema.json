{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/experiment-review-packet-v0.schema.json",
  "title": "experiment-review-packet-v0",
  "type": "object",
  "required": [
    "record_type",
    "packet_id",
    "proposal_id",
    "proposal_sha256",
    "generated_at_utc",
    "git_commit",
    "proposal_summary",
    "dry_run_summary",
    "safety_gate_summary",
    "risk_summary",
    "approval_status",
    "approved_for_execution",
    "execution_blocked",
    "warnings",
    "recommended_decision",
    "output_paths",
    "canonical_corpus_active",
    "page_boundaries_final",
    "trusted_as_canonical"
  ],
  "properties": {
    "record_type": { "const": "experiment_review_packet" },
    "packet_id": { "type": "string", "minLength": 1 },
    "proposal_id": { "type": "string", "minLength": 1 },
    "proposal_sha256": { "type": "string", "minLength": 64 },
    "generated_at_utc": { "type": "string" },
    "git_commit": { "type": "string" },
    "proposal_summary": { "type": "object" },
    "dry_run_summary": { "type": "object" },
    "safety_gate_summary": { "type": "object" },
    "risk_summary": { "type": "object" },
    "approval_status": { "type": "string" },
    "approved_for_execution": { "const": false },
    "execution_blocked": { "const": true },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "recommended_decision": { "type": "string" },
    "output_paths": { "type": "object" },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "trusted_as_canonical": { "const": false }
  },
  "additionalProperties": true
}
