{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/liberprimus-gpu/schemas/experiments/exploratory-experiment-manifest-v0.schema.json",
  "title": "exploratory-experiment-manifest-v0",
  "type": "object",
  "required": [
    "record_type",
    "manifest_id",
    "manifest_version",
    "description",
    "experiment_stage",
    "dry_run_only",
    "execution_enabled",
    "search_execution_enabled",
    "candidate_generation_enabled",
    "scoring_enabled",
    "cuda_enabled",
    "canonical_corpus_active",
    "page_boundaries_final",
    "trusted_as_canonical",
    "corpus_slice",
    "transform_plan",
    "parameter_space",
    "safety_gates",
    "expected_candidate_count_upper_bound",
    "result_store_policy",
    "output_policy",
    "provenance",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "exploratory_experiment_manifest" },
    "manifest_id": { "type": "string", "minLength": 1 },
    "manifest_version": { "type": "string" },
    "description": { "type": "string" },
    "experiment_stage": { "type": "string" },
    "dry_run_only": { "const": true },
    "execution_enabled": { "const": false },
    "search_execution_enabled": { "const": false },
    "candidate_generation_enabled": { "const": false },
    "scoring_enabled": { "const": false },
    "cuda_enabled": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "trusted_as_canonical": { "const": false },
    "corpus_slice": { "type": "object" },
    "transform_plan": { "type": "object" },
    "parameter_space": { "type": "object" },
    "safety_gates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_candidate_count_upper_bound": { "type": "integer", "minimum": 0 },
    "result_store_policy": { "type": "object" },
    "output_policy": { "type": "object" },
    "provenance": { "type": "object" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
