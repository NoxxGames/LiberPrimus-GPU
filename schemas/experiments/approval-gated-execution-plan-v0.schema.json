{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/approval-gated-execution-plan-v0.schema.json",
  "title": "approval-gated-execution-plan-v0",
  "type": "object",
  "required": [
    "record_type",
    "plan_id",
    "request_id",
    "proposal_id",
    "proposal_sha256",
    "approval_id",
    "approval_status",
    "approved_for_execution",
    "execution_scope",
    "generated_at_utc",
    "git_commit",
    "approval_gate_status",
    "blocking_reasons",
    "safety_gate_results",
    "execution_manifest_preview",
    "output_paths",
    "unsolved_execution_allowed",
    "search_execution_enabled",
    "candidate_generation_enabled",
    "scoring_enabled",
    "cuda_enabled",
    "canonical_corpus_active",
    "page_boundaries_final",
    "trusted_as_canonical",
    "warnings"
  ],
  "properties": {
    "record_type": { "const": "approval_gated_execution_plan" },
    "plan_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "proposal_id": { "type": "string", "minLength": 1 },
    "proposal_sha256": { "type": "string", "minLength": 64 },
    "approval_id": { "type": "string" },
    "approval_status": { "type": "string" },
    "approved_for_execution": { "type": "boolean" },
    "execution_scope": {
      "type": "string",
      "enum": ["synthetic_only", "solved_fixture_only", "synthetic_and_solved_fixture_only", "no_op_review_only"]
    },
    "generated_at_utc": { "type": "string" },
    "git_commit": { "type": "string" },
    "approval_gate_status": { "type": "string", "enum": ["pass", "blocked", "warning", "error"] },
    "blocking_reasons": { "type": "array", "items": { "type": "string" } },
    "safety_gate_results": { "type": "array", "items": { "type": "object" } },
    "execution_manifest_preview": { "type": "object" },
    "output_paths": { "type": "object" },
    "unsolved_execution_allowed": { "const": false },
    "search_execution_enabled": { "const": false },
    "candidate_generation_enabled": { "const": false },
    "scoring_enabled": { "const": false },
    "cuda_enabled": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "trusted_as_canonical": { "const": false },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": {
        "properties": { "approved_for_execution": { "const": false } },
        "required": ["approved_for_execution"]
      },
      "then": {
        "properties": { "approval_gate_status": { "const": "blocked" } }
      }
    }
  ],
  "additionalProperties": true
}
