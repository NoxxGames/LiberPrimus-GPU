{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/experiments/bounded-candidate-record-v0.schema.json",
  "title": "bounded-candidate-record-v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "run_id",
    "queue_item_id",
    "transform_family",
    "transform_id",
    "transform_parameters",
    "candidate_index",
    "input_slice_id",
    "output_normalized_text",
    "output_sha256",
    "score_summary",
    "ranking_features",
    "search_performed",
    "scoring_used",
    "cuda_used",
    "canonical_corpus_active",
    "page_boundaries_final",
    "solve_claim",
    "trusted_as_canonical",
    "warnings"
  ],
  "properties": {
    "record_type": { "const": "bounded_candidate_record" },
    "run_id": { "type": "string", "minLength": 1 },
    "queue_item_id": { "type": "string", "minLength": 1 },
    "transform_family": { "type": "string", "minLength": 1 },
    "transform_id": { "type": "string", "minLength": 1 },
    "transform_parameters": { "type": "object" },
    "candidate_index": { "type": "integer", "minimum": 0 },
    "input_slice_id": { "type": "string", "minLength": 1 },
    "output_normalized_text": { "type": "string" },
    "output_preview": { "type": "string" },
    "output_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
    "score_summary": { "type": "object" },
    "ranking_features": { "type": "object" },
    "search_performed": { "const": true },
    "scoring_used": { "const": true },
    "cuda_used": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "solve_claim": { "const": false },
    "trusted_as_canonical": { "const": false },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
