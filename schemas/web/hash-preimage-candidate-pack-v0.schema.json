{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/web/hash-preimage-candidate-pack-v0.schema.json",
  "title": "Hash Preimage Candidate Pack v0",
  "type": "object",
  "required": [
    "record_type",
    "pack_id",
    "description",
    "algorithm",
    "source_class",
    "candidate_groups",
    "byte_variants",
    "candidate_count_upper_bound",
    "generated_from_external_dictionary",
    "cuda_enabled",
    "cloud_execution",
    "no_solve_claim",
    "trusted_as_canonical",
    "notes"
  ],
  "properties": {
    "record_type": { "const": "hash_preimage_candidate_pack" },
    "pack_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "algorithm": { "const": "sha256" },
    "source_class": {
      "enum": [
        "primary_signed",
        "strong_community_technical",
        "secondary_archive",
        "reference_only_tooling",
        "archived_claim",
        "speculative_observation",
        "negative_control_material"
      ]
    },
    "candidate_groups": { "type": "object" },
    "byte_variants": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "candidate_count_upper_bound": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "generated_from_external_dictionary": { "const": false },
    "cuda_enabled": { "const": false },
    "cloud_execution": { "const": false },
    "no_solve_claim": { "const": true },
    "trusted_as_canonical": { "const": false },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
