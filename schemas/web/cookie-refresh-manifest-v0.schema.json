{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/web/cookie-refresh-manifest-v0.schema.json",
  "title": "Stage 4G cookie refresh manifest v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "manifest_id",
    "candidate_count_upper_bound",
    "source_basis",
    "byte_variants",
    "algorithms",
    "exact_match_only",
    "fuzzy_matching",
    "partial_matching",
    "broad_search",
    "hashcat_used",
    "cuda_enabled",
    "cloud_execution",
    "no_solve_claim"
  ],
  "properties": {
    "record_type": { "type": "string", "minLength": 1 },
    "manifest_id": { "type": "string", "minLength": 1 },
    "candidate_count_upper_bound": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "source_basis": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "byte_variants": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "algorithms": {
      "type": "array",
      "items": { "enum": ["sha256", "sha1", "sha512", "md5"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "exact_match_only": { "const": true },
    "fuzzy_matching": { "const": false },
    "partial_matching": { "const": false },
    "broad_search": { "const": false },
    "hashcat_used": { "const": false },
    "cuda_enabled": { "const": false },
    "cloud_execution": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false }
  }
}
