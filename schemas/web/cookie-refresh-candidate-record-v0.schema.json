{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/web/cookie-refresh-candidate-record-v0.schema.json",
  "title": "Stage 4G cookie refresh candidate record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "experiment_id",
    "candidate_id",
    "base_string_id",
    "source_record_id",
    "source_basis",
    "raw_string_redacted_if_needed",
    "byte_variant",
    "encoding",
    "algorithm",
    "candidate_bytes_sha256",
    "digest_hex",
    "target_cookie_id",
    "target_cookie_value",
    "exact_match",
    "previous_pack_duplicate",
    "no_solve_claim",
    "cuda_used",
    "cloud_execution",
    "trusted_as_canonical",
    "exact_match_only",
    "fuzzy_matching",
    "partial_matching",
    "hashcat_used"
  ],
  "properties": {
    "record_type": { "const": "cookie_refresh_candidate_record" },
    "experiment_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "base_string_id": { "type": "string", "minLength": 1 },
    "source_record_id": { "type": "string", "minLength": 1 },
    "source_basis": { "type": "string", "minLength": 1 },
    "raw_string_redacted_if_needed": { "type": "string" },
    "byte_variant": { "type": "string", "minLength": 1 },
    "encoding": { "const": "utf-8" },
    "algorithm": { "enum": ["sha256", "sha1", "sha512", "md5"] },
    "candidate_bytes_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "digest_hex": { "type": "string", "pattern": "^[0-9a-f]+$" },
    "target_cookie_id": { "type": "string", "minLength": 1 },
    "target_cookie_value": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "exact_match": { "type": "boolean" },
    "previous_pack_duplicate": { "type": "boolean" },
    "no_solve_claim": { "const": true },
    "cuda_used": { "const": false },
    "cloud_execution": { "const": false },
    "trusted_as_canonical": { "const": false },
    "exact_match_only": { "const": true },
    "fuzzy_matching": { "const": false },
    "partial_matching": { "const": false },
    "hashcat_used": { "const": false },
    "broad_search": { "const": false }
  }
}
