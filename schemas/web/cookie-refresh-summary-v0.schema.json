{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/web/cookie-refresh-summary-v0.schema.json",
  "title": "Stage 4G cookie refresh summary v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage",
    "experiment_id",
    "target_cookie_count",
    "source_backed_base_string_count",
    "byte_variant_count",
    "algorithms_run",
    "generated_candidates_before_dedup",
    "candidates_after_dedup",
    "duplicate_count",
    "previous_pack_duplicate_count",
    "comparison_count",
    "exact_match_count",
    "candidate_count_upper_bound",
    "exact_match_only",
    "fuzzy_matching",
    "partial_matching",
    "hashcat_used",
    "cuda_used",
    "cloud_execution",
    "no_solve_claim",
    "trusted_as_canonical",
    "generated_outputs_committed"
  ],
  "properties": {
    "record_type": { "const": "cookie_refresh_summary" },
    "stage": { "const": "stage4g" },
    "experiment_id": { "type": "string", "minLength": 1 },
    "target_cookie_count": { "type": "integer", "minimum": 0 },
    "source_backed_base_string_count": { "type": "integer", "minimum": 0 },
    "byte_variant_count": { "type": "integer", "minimum": 0 },
    "algorithms_run": {
      "type": "array",
      "items": { "enum": ["sha256", "sha1", "sha512", "md5"] },
      "minItems": 1
    },
    "generated_candidates_before_dedup": { "type": "integer", "minimum": 0 },
    "candidates_after_dedup": { "type": "integer", "minimum": 0 },
    "duplicate_count": { "type": "integer", "minimum": 0 },
    "previous_pack_duplicate_count": { "type": "integer", "minimum": 0 },
    "comparison_count": { "type": "integer", "minimum": 0 },
    "exact_match_count": { "type": "integer", "minimum": 0 },
    "candidate_count_upper_bound": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "exact_match_only": { "const": true },
    "fuzzy_matching": { "const": false },
    "partial_matching": { "const": false },
    "hashcat_used": { "const": false },
    "cuda_used": { "const": false },
    "cloud_execution": { "const": false },
    "no_solve_claim": { "const": true },
    "trusted_as_canonical": { "const": false },
    "generated_outputs_committed": { "const": false }
  }
}
