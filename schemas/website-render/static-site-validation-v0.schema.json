{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/website-render/static-site-validation-v0.schema.json",
  "title": "Stage 5AM static site validation",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "static_site_validation_passed",
    "robots_noindex_present",
    "robots_disallow_all_present",
    "external_network_dependencies_present",
    "raw_bodies_included",
    "private_ids_published",
    "public_website_publication_performed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "stage5am_static_site_validation" },
    "stage_id": { "const": "stage-5am" },
    "static_site_validation_passed": { "type": "boolean" },
    "robots_noindex_present": { "type": "boolean" },
    "robots_disallow_all_present": { "type": "boolean" },
    "external_network_dependencies_present": { "const": false },
    "raw_bodies_included": { "const": false },
    "private_ids_published": { "const": false },
    "public_website_publication_performed": { "const": false },
    "solve_claim": { "const": false }
  }
}
