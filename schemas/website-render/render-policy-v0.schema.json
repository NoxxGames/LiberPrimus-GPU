{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/website-render/render-policy-v0.schema.json",
  "title": "Stage 5AM render policy",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "metadata_only",
    "raw_bodies_included",
    "private_ids_published",
    "public_website_publication_performed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "stage5am_render_policy" },
    "stage_id": { "const": "stage-5am" },
    "metadata_only": { "const": true },
    "raw_bodies_included": { "const": false },
    "private_ids_published": { "const": false },
    "public_website_publication_performed": { "const": false },
    "deep_research_performed": { "const": false },
    "solve_claim": { "const": false }
  }
}
