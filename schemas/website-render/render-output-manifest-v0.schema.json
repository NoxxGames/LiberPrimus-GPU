{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/website-render/render-output-manifest-v0.schema.json",
  "title": "Stage 5AM render output manifest",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "metadata_only",
    "website_export_generated",
    "upload_directory",
    "static_pages_generated",
    "data_json_files_generated",
    "raw_bodies_included",
    "private_ids_published",
    "public_website_publication_performed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "stage5am_render_output_manifest" },
    "stage_id": { "const": "stage-5am" },
    "metadata_only": { "const": true },
    "website_export_generated": { "const": true },
    "upload_directory": { "const": "website-export/stage5am/research-index" },
    "static_pages_generated": { "type": "integer", "minimum": 9 },
    "data_json_files_generated": { "type": "integer", "minimum": 8 },
    "raw_bodies_included": { "const": false },
    "private_ids_published": { "const": false },
    "public_website_publication_performed": { "const": false },
    "solve_claim": { "const": false }
  }
}
