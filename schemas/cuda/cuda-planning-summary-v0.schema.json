{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/cuda/cuda-planning-summary-v0.schema.json",
  "title": "CUDA Planning Summary v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "status",
    "target_plan_records",
    "ready_targets",
    "blocked_targets",
    "non_target_records",
    "parity_scaffold_records",
    "implementation_gate_records",
    "satisfied_gates",
    "blocked_deferred_gates",
    "stage4o_parity_references_used",
    "stage4p_unified_result_references_used",
    "cuda_planning_only",
    "cuda_implementation_added",
    "cuda_kernel_added",
    "cuda_source_modified",
    "gpu_benchmark_performed",
    "performance_claim",
    "speedup_claim",
    "broad_experiment_executed",
    "raw_data_processed",
    "solve_claim",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "codex_output_committed"
  ],
  "properties": {
    "record_type": { "const": "stage5a_cuda_planning_summary" },
    "stage_id": { "const": "stage-5a" },
    "status": { "const": "complete" },
    "target_plan_records": { "type": "integer", "minimum": 0 },
    "ready_targets": { "type": "integer", "minimum": 0 },
    "blocked_targets": { "type": "integer", "minimum": 0 },
    "non_target_records": { "type": "integer", "minimum": 0 },
    "parity_scaffold_records": { "type": "integer", "minimum": 0 },
    "implementation_gate_records": { "type": "integer", "minimum": 0 },
    "satisfied_gates": { "type": "integer", "minimum": 0 },
    "blocked_deferred_gates": { "type": "integer", "minimum": 0 },
    "stage4o_parity_references_used": { "type": "integer", "minimum": 0 },
    "stage4p_unified_result_references_used": { "type": "integer", "minimum": 0 },
    "cuda_planning_only": { "const": true },
    "cuda_implementation_added": { "const": false },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false }
  }
}
