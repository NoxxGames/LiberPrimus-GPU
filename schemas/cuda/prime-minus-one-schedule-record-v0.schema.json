{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "cuda_execution_allowed": { "const": false },
    "deterministic": { "const": true },
    "first_n_primes": { "items": { "type": "integer" }, "type": "array" },
    "formula": { "const": "(prime_i - 1) mod 29" },
    "generated_body_publication_allowed": { "const": false },
    "native_execution_allowed": { "const": false },
    "no_solve_claim": { "const": true },
    "prime_index_base": { "const": 0 },
    "raw_data_required": { "const": false },
    "record_type": { "const": "prime_minus_one_schedule_record" },
    "schedule_id": { "type": "string" },
    "solve_claim": { "const": false },
    "stage_id": { "const": "stage-5w" },
    "stream_values_mod29": { "items": { "minimum": 0, "maximum": 28, "type": "integer" }, "type": "array" },
    "value_count": { "minimum": 0, "type": "integer" }
  },
  "required": [
    "record_type",
    "stage_id",
    "schedule_id",
    "prime_index_base",
    "first_n_primes",
    "stream_values_mod29",
    "formula",
    "value_count",
    "deterministic",
    "raw_data_required",
    "native_execution_allowed",
    "cuda_execution_allowed"
  ],
  "type": "object"
}
