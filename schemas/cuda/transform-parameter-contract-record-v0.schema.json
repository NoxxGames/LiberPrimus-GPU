{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/cuda/transform-parameter-contract-record-v0.schema.json",
  "title": "transform-parameter-contract-record-v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "transform_parameter_contract_id",
    "family_id",
    "contract_status",
    "parameter_layout",
    "parameter_value_domains",
    "implementation_allowed_now",
    "compatible_with_candidate_batch_abi_v0",
    "cuda_execution_performed",
    "cuda_source_modified",
    "generated_outputs_committed",
    "no_solve_claim",
    "solve_claim"
  ],
  "properties": {
    "record_type": {"const": "transform_parameter_contract_record"},
    "stage_id": {"const": "stage-5u"},
    "transform_parameter_contract_id": {"type": "string"},
    "family_id": {"type": "string"},
    "contract_status": {"type": "string"},
    "parameter_layout": {"type": "array", "items": {"type": "string"}},
    "parameter_value_domains": {"type": "object"},
    "implementation_allowed_now": {"const": false},
    "compatible_with_candidate_batch_abi_v0": {"const": true},
    "cuda_execution_performed": {"const": false},
    "cuda_source_modified": {"const": false},
    "new_cuda_kernel_added": {"const": false},
    "new_cuda_kernels_added": {"const": 0},
    "gpu_benchmark_performed": {"const": false},
    "unsolved_page_cuda_used": {"const": false},
    "generated_outputs_committed": {"const": false},
    "raw_data_processed": {"const": false},
    "method_status_upgraded": {"const": false},
    "no_solve_claim": {"const": true},
    "solve_claim": {"const": false},
    "no_gpu_ci_safe": {"const": true}
  }
}
