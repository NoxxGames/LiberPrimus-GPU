{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/cuda-future-kernel-parity-matrix-v0.schema.json",
  "title": "CUDA Future Kernel Parity Matrix v0",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "kernel_id",
    "future_kernel_status",
    "cpu_reference_required",
    "cpu_reference_present",
    "vram_profile",
    "no_fast_math_default",
    "cuda_kernel_added",
    "gpu_benchmark_performed",
    "speedup_claim",
    "solve_claim",
    "no_solve_claim",
    "generated_outputs_committed",
    "codex_output_committed"
  ],
  "properties": {
    "record_type": { "const": "cuda_future_kernel_parity_matrix_record" },
    "stage_id": { "const": "stage-5b" },
    "kernel_id": { "type": "string", "minLength": 1 },
    "future_kernel_status": { "enum": ["not_implemented", "blocked", "planned", "deferred"] },
    "cpu_reference_family": { "type": "string" },
    "cpu_reference_required": { "const": true },
    "cpu_reference_present": { "type": "boolean" },
    "required_fixture_count": { "type": "integer", "minimum": 0 },
    "required_positive_controls": { "type": "integer", "minimum": 0 },
    "required_null_controls": { "type": "integer", "minimum": 0 },
    "required_negative_controls": { "type": "integer", "minimum": 0 },
    "vram_profile": { "enum": ["compatibility_8gb", "local_16gb", "ci_no_gpu", "not_applicable"] },
    "local_16gb_profile_required": { "const": false },
    "no_fast_math_default": { "const": true },
    "no_performance_claim": { "const": true },
    "cuda_implementation_added": { "const": false },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "website_expansion": { "const": false }
  },
  "additionalProperties": true
}
