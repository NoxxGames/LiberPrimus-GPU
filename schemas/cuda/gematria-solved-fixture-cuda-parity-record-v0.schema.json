{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/cuda/gematria-solved-fixture-cuda-parity-record-v0.schema.json",
  "type": "object",
  "required": [
    "record_type",
    "parity_record_id",
    "run_record_id",
    "mapping_id",
    "fixture_id",
    "executed_kernel",
    "executed_semantics",
    "expected_native_output_token_hash",
    "cuda_output_token_hash",
    "cuda_native_hash_match",
    "parity_status",
    "cuda_run_status",
    "cuda_build_status",
    "stage5n_ready",
    "solved_fixture_cuda_execution_allowed",
    "unsolved_page_cuda_used",
    "real_liber_primus_cuda_data_used",
    "gpu_benchmark_performed",
    "performance_claim",
    "speedup_claim",
    "no_solve_claim",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "gematria_solved_fixture_cuda_parity_record" },
    "executed_kernel": { "const": "gematria_mod29_shift_score_kernel" },
    "executed_semantics": { "const": "gematria_shift_score_only" },
    "parity_status": {
      "enum": [
        "passed",
        "failed_hash_mismatch",
        "failed_cuda_run",
        "skipped_missing_cuda",
        "skipped_not_requested",
        "skipped_build_not_passed",
        "skipped_executable_missing",
        "unknown"
      ]
    },
    "cuda_native_hash_match": { "type": ["boolean", "null"] },
    "solved_fixture_cuda_execution_allowed": { "const": true },
    "unsolved_page_cuda_used": { "const": false },
    "real_liber_primus_cuda_data_used": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "device_kernel_arithmetic_modified": { "const": false },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
