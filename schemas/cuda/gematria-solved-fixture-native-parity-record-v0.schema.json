{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/libreprimus/schemas/cuda/gematria-solved-fixture-native-parity-record-v0.schema.json",
  "title": "Gematria solved-fixture native parity record v0",
  "type": "object",
