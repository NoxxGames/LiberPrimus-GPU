{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/gematria-cuda-result-store-preflight-record-v0.schema.json",
  "title": "Gematria CUDA Result Store Preflight Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "preflight_record_id",
    "preflight_kind",
    "result_source_kind",
    "stage4p_compatibility_required",
    "stage4i_confidence_labels_only",
    "confidence_label_interpretation",
    "output_token_hash_required",
    "preflight_status",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "gematria_cuda_result_store_preflight_record" },
    "preflight_record_id": { "type": "string" },
    "preflight_kind": { "enum": ["result_store", "score_summary"] },
    "result_source_kind": { "const": "solved_fixture_safe_cuda_parity" },
    "stage4p_compatibility_required": { "const": true },
    "stage4i_confidence_labels_only": { "const": true },
    "confidence_label_interpretation": { "const": "triage_only" },
    "output_token_hash_required": { "const": true },
    "method_status_upgrade_allowed": { "const": false },
    "additional_cuda_execution_performed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "real_liber_primus_cuda_data_used": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "cuda_source_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "speedup_claim": { "const": false },
    "generated_outputs_committed": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false }
  }
}
