{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/cuda/bounded-p56-cuda-run-record-v0.schema.json",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "validation_vector_id",
    "mapping_id",
    "fixture_id",
    "candidate_id",
    "expected_output_token_hash",
    "computed_cuda_output_token_hash",
    "cuda_execution_status",
    "cuda_attempted_count",
    "cuda_pass_count",
    "cuda_fail_count",
    "cuda_skip_count",
    "full_p56_cuda_executed",
    "unsolved_page_cuda_used",
    "gpu_benchmark_performed",
    "scored_experiment_executed",
    "generated_outputs_committed",
    "solve_claim"
  ],
  "properties": {
    "record_type": {"const": "bounded_p56_cuda_run_record"},
    "stage_id": {"const": "stage-5ad"},
    "validation_vector_id": {"const": "stage5z-validation-p56-bounded-v0"},
    "cuda_execution_status": {
      "enum": [
        "passed",
        "failed_hash_mismatch",
        "skipped_cuda_unavailable",
        "skipped_cuda_build_unavailable",
        "skipped_cuda_device_unavailable",
        "skipped_missing_bounded_vector",
        "skipped_validation_failed",
        "blocked_full_p56"
      ]
    },
    "full_p56_cuda_executed": {"const": false},
    "unsolved_page_cuda_used": {"const": false},
    "gpu_benchmark_performed": {"const": false},
    "scored_experiment_executed": {"const": false},
    "generated_outputs_committed": {"const": false},
    "solve_claim": {"const": false},
    "no_solve_claim": {"const": true}
  },
  "additionalProperties": true
}
