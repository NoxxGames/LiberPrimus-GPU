{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/cuda/gematria-cuda-expansion-decision-record-v0.schema.json",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "expansion_decision_id",
    "decision_status",
    "stage5p_ready",
    "selected_next_stage",
    "remaining_blockers",
    "broad_solved_fixture_cuda_allowed",
    "unsolved_page_cuda_allowed",
    "gpu_benchmark_allowed",
    "cuda_source_modified",
    "new_cuda_kernels_added",
    "gpu_benchmark_performed",
    "speedup_claim",
    "unsolved_page_cuda_used",
    "no_solve_claim",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "gematria_cuda_expansion_decision_record" },
    "stage_id": { "const": "stage-5o" },
    "decision_status": {
      "enum": [
