{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liberprimus-gpu.local/schemas/cuda/solved-family-cuda-parity-matrix-record-v0.schema.json",
  "title": "solved-family-cuda-parity-matrix-record-v0",
  "type": "object",
  "additionalProperties": true,
  "required": ["record_type", "solved_family_id", "readiness_status", "original_transform_semantics_cuda_verified", "cuda_execution_performed", "solve_claim"],
  "properties": {
    "record_type": {"const": "solved_family_cuda_parity_matrix_record"},
    "solved_family_id": {"type": "string"},
    "readiness_status": {
      "enum": [
        "cuda_parity_verified_existing_kernel",
        "cuda_parity_ready_existing_kernel",
        "cpu_native_reference_ready",
        "needs_cuda_kernel_contract",
        "needs_batch_abi",
        "needs_result_store_shape",
        "needs_score_summary_shape",
        "blocked_original_transform_contract",
        "blocked_requires_source_lock_or_token_mapping",
        "blocked_broad_scope",
        "blocked_unsolved",
        "not_cuda_target"
      ]
    },
    "original_transform_semantics_cuda_verified": {"type": "boolean"},
    "cuda_execution_performed": {"const": false},
    "cuda_source_modified": {"const": false},
    "new_cuda_kernel_added": {"const": false},
    "gpu_benchmark_performed": {"const": false},
    "solve_claim": {"const": false},
    "no_solve_claim": {"const": true}
  }
}
