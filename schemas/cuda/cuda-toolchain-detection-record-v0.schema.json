{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/cuda/cuda-toolchain-detection-record-v0.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "tool_id",
    "tool_status",
    "tool_required_for_ci",
    "absolute_path_committed",
    "cuda_required",
    "gpu_required",
    "cuda_kernel_added",
    "cryptanalytic_cuda_kernel_added",
    "gpu_benchmark_performed",
    "performance_claim",
    "speedup_claim",
    "raw_data_processed",
    "solve_claim",
    "no_solve_claim",
    "generated_outputs_committed",
    "codex_output_committed"
  ],
  "properties": {
    "record_type": { "const": "cuda_toolchain_detection_record" },
    "stage_id": { "const": "stage-5c" },
    "tool_id": {
      "enum": [
        "cmake",
        "nvcc",
        "nvidia_smi"
      ]
    },
    "tool_status": {
      "enum": [
        "detected",
        "missing",
        "probe_failed"
      ]
    },
    "tool_required_for_ci": { "const": false },
    "absolute_path_committed": { "const": false },
    "cuda_required": { "const": false },
    "gpu_required": { "const": false },
    "local_16gb_profile_required": { "const": false },
    "compatibility_8gb_profile_present": { "const": true },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "cryptanalytic_cuda_kernel_added": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "website_expansion": { "const": false }
  }
}
