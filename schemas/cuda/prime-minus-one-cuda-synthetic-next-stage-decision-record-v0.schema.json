{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/prime-minus-one-cuda-synthetic-next-stage-decision-record-v0.schema.json",
  "title": "Prime Minus One CUDA Synthetic Next Stage Decision Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": ["record_type", "stage_id", "option_id", "selected", "recommended_stage_title", "blockers", "solve_claim"],
  "properties": {
    "record_type": { "const": "prime_minus_one_cuda_synthetic_next_stage_decision_record" },
    "stage_id": { "enum": ["stage-5aa", "stage-5ac"] },
    "recommended_prompt_type": { "enum": ["Codex", "Deep Research"] },
    "cuda_execution_allowed_current_stage": { "const": false },
    "cuda_source_changes_allowed_current_stage": { "const": false },
    "benchmark_execution_allowed": { "const": false },
    "scored_experiment_execution_allowed": { "const": false },
    "unsolved_page_scope_allowed": { "const": false },
    "generated_body_publication_allowed": { "const": false },
    "method_status_upgrade_allowed": { "const": false },
    "cuda_execution_performed": { "enum": [false, null] },
    "cuda_source_modified": { "type": "boolean" },
    "new_cuda_kernels_added": { "type": "integer", "minimum": 0 },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true }
  }
}
