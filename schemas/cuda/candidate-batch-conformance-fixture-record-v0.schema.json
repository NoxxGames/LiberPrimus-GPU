{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/cuda/candidate-batch-conformance-fixture-record-v0.schema.json",
  "title": "candidate-batch-conformance-fixture-record-v0",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "candidate_batch_abi_id",
    "fixture_id",
    "fixture_kind",
    "token_values",
    "token_kind",
    "transformable_mask",
    "fixture_offsets",
    "fixture_lengths",
    "execution_status",
    "raw_data_free",
    "no_gpu_safe",
    "cuda_execution_performed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "candidate_batch_conformance_fixture_record" },
    "stage_id": { "const": "stage-5v" },
    "candidate_batch_abi_id": { "const": "candidate_batch_abi_v0" },
    "token_values": { "type": "array", "items": { "type": "integer" } },
    "token_kind": { "type": "array", "items": { "type": "string" } },
    "transformable_mask": { "type": "array", "items": { "type": "boolean" } },
    "raw_data_free": { "const": true },
    "no_gpu_safe": { "const": true },
    "candidate_ordering": { "const": "candidate_major" },
    "output_ordering": { "const": "candidate_major_then_token_position" },
    "cuda_execution_performed": { "const": false },
    "cuda_source_modified": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "real_liber_primus_cuda_data_used": { "const": false },
    "generated_outputs_committed": { "const": false },
    "raw_data_processed": { "const": false },
    "generated_body_publication_allowed": { "const": false },
    "method_status_upgraded": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "no_gpu_ci_safe": { "const": true }
  },
  "additionalProperties": true
}
