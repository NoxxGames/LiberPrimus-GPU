{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/libreprimus/schemas/cuda/gematria-solved-fixture-token-mapping-record-v0.schema.json",
  "title": "Gematria solved-fixture token mapping record v0",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "mapping_id",
    "source_input_stream_id",
    "fixture_id",
    "mapping_status",
    "token_domain",
    "token_values",
    "token_kinds",
    "transformable_mask",
    "separator_metadata_preserved",
    "token_kind_metadata_preserved",
    "solved_fixture_cuda_execution_allowed",
    "cuda_execution_performed",
    "new_cuda_kernels_added",
    "cuda_source_modified",
    "real_liber_primus_cuda_data_used",
    "unsolved_page_cuda_used",
    "no_gpu_ci_safe",
    "no_solve_claim",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "gematria_solved_fixture_token_mapping_record" },
    "stage_id": { "const": "stage-5l" },
    "mapping_status": { "enum": ["mapped", "blocked"] },
    "token_domain": { "const": "integers_0_to_28" },
    "token_values": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "integer", "minimum": 0, "maximum": 28 },
          { "type": "null" }
        ]
      }
    },
    "token_kinds": { "type": "array", "items": { "type": "string" } },
    "transformable_mask": { "type": "array", "items": { "type": "boolean" } },
    "separator_metadata_preserved": { "const": true },
    "token_kind_metadata_preserved": { "const": true },
    "solved_fixture_cuda_execution_allowed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "cuda_source_modified": { "const": false },
    "real_liber_primus_cuda_data_used": { "const": false },
    "solved_fixture_cuda_used": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "raw_data_processed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "no_gpu_ci_safe": { "const": true },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
