{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/prime-minus-one-cuda-synthetic-scored-experiment-deferral-record-v0.schema.json",
  "title": "Prime Minus One CUDA Synthetic Scored Experiment Deferral Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": ["record_type", "stage_id", "deferral_record_id", "experiment_class", "execution_enabled", "benchmark_execution_allowed", "scored_experiment_executed", "solve_claim"],
  "properties": {
    "record_type": { "const": "prime_minus_one_cuda_synthetic_scored_experiment_deferral_record" },
    "stage_id": { "enum": ["stage-5aa", "stage-5ac"] },
    "deferral_status": { "type": "string" },
    "readiness_status": { "type": "string" },
    "execution_enabled": { "const": false },
    "cuda_execution_performed": { "enum": [false, null] },
    "cuda_source_modified": { "type": "boolean" },
    "new_cuda_kernels_added": { "type": "integer", "minimum": 0 },
    "benchmark_execution_allowed": { "const": false },
    "scored_experiment_executed": { "const": false },
    "unsolved_page_cuda_allowed": { "const": false },
    "website_expansion_status": { "enum": ["deferred_future_unnumbered_project", "not_applicable"] },
    "generated_body_publication_allowed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true }
  }
}
