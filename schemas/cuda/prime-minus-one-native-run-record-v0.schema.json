{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/prime-minus-one-native-run-record-v0.schema.json",
  "title": "Prime Minus One Native Run Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "source_stage_id",
    "candidate_batch_abi_id",
    "contract_id",
    "mapping_id",
    "fixture_id",
    "stream_schedule_ref",
    "expected_output_token_hash",
    "computed_output_token_hash",
    "output_hash_algorithm",
    "native_execution_status",
    "native_execution_performed",
    "python_reference_execution_performed",
    "cuda_execution_performed",
    "cuda_source_modified",
    "new_cuda_kernels_added",
    "gpu_benchmark_performed",
    "speedup_claim",
    "solve_claim",
    "no_solve_claim"
  ],
  "properties": {
    "record_type": { "const": "prime_minus_one_native_run_record" },
    "stage_id": { "const": "stage-5x" },
    "source_stage_id": { "const": "stage-5w" },
    "candidate_batch_abi_id": { "const": "candidate_batch_abi_v0" },
    "contract_id": { "const": "prime_minus_one_stream_native_contract_v0" },
    "native_execution_status": {
      "enum": ["passed", "failed_hash_mismatch", "skipped_blocked_full_p56"]
    },
    "output_hash_algorithm": { "const": "sha256_canonical_json_v1" },
    "native_cpu_execution_performed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "cuda_source_modified": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "device_kernel_arithmetic_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "benchmark_execution_allowed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "unsolved_page_cuda_allowed": { "const": false },
    "real_liber_primus_cuda_data_used": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_body_publication_allowed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "raw_data_processed": { "const": false },
    "codex_output_committed": { "const": false },
    "method_status_upgrade_allowed": { "const": false },
    "method_status_upgraded": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "ci_gpu_required": { "const": false },
    "local_16gb_profile_required": { "const": false },
    "cxx_launches_python_workers": { "const": false }
  }
}
