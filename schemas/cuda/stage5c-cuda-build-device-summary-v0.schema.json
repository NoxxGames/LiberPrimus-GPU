{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/cuda/stage5c-cuda-build-device-summary-v0.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "status",
    "build_profile_records",
    "toolchain_detection_records",
    "device_detection_records",
    "smoke_build_records",
    "cuda_toolchain_available",
    "cuda_device_available",
    "local_16gb_profile_detected",
    "local_16gb_profile_required",
    "compatibility_8gb_profile_present",
    "no_gpu_ci_profile_present",
    "smoke_build_attempted",
    "smoke_build_status",
    "cuda_kernel_added",
    "cryptanalytic_cuda_kernel_added",
    "gpu_benchmark_performed",
    "performance_claim",
    "speedup_claim",
    "raw_data_processed",
    "solve_claim",
    "no_solve_claim",
    "generated_outputs_committed",
    "codex_output_committed",
    "next_stage"
  ],
  "properties": {
    "record_type": { "const": "stage5c_cuda_build_device_summary" },
    "stage_id": { "const": "stage-5c" },
    "status": { "const": "complete" },
    "build_profile_records": { "type": "integer", "minimum": 3 },
    "toolchain_detection_records": { "type": "integer", "minimum": 3 },
    "device_detection_records": { "type": "integer", "minimum": 3 },
    "smoke_build_records": { "type": "integer", "minimum": 1 },
    "cuda_toolchain_available": { "enum": [true, false, "unknown"] },
    "cuda_device_available": { "enum": [true, false, "unknown"] },
    "local_16gb_profile_detected": { "enum": [true, false, "unknown"] },
    "local_16gb_profile_required": { "const": false },
    "compatibility_8gb_profile_present": { "const": true },
    "no_gpu_ci_profile_present": { "const": true },
    "smoke_build_attempted": { "type": "boolean" },
    "smoke_build_status": {
      "enum": [
        "passed",
        "failed",
        "skipped"
      ]
    },
    "cuda_required": { "const": false },
    "gpu_required": { "const": false },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "cryptanalytic_cuda_kernel_added": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "website_expansion": { "const": false },
    "next_stage": { "const": "Stage 5D - native C++ CPU batch backend and deterministic threading baseline" }
  }
}
