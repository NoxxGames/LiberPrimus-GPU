  "properties": {
    "record_type": {"const": "gematria_expanded_solved_fixture_score_summary_preflight_record"},
    "stage_id": {"const": "stage-5r"},
    "source_stage_id": {"const": "stage-5q"},
    "score_summary_contract": {"const": "stage4i"},
    "score_interpretation": {"const": "triage_only"},
    "confidence_label": {"enum": ["scoring_not_available", "calibration_not_available", "none", "very_low", "low", "medium", "high", "very_high", "control"]},
