  "title": "Stage 5R expanded solved-fixture score-summary preflight record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "source_stage_id",
    "score_summary_preflight_id",
    "parity_record_id",
    "score_summary_contract",
    "score_interpretation",
    "confidence_label",
    "score_status",
    "new_scorer_added",
    "method_status_upgrade_allowed",
    "solve_claim"
