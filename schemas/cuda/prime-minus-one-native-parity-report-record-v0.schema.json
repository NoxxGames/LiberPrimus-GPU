    "candidate_batch_abi_id": { "const": "candidate_batch_abi_v0" },
    "native_parity_status": { "enum": ["passed", "failed_hash_mismatch", "blocked_not_executed"] },
    "output_hash_algorithm": { "const": "sha256_canonical_json_v1" },
    "compact_summary_only": { "const": true },
    "metadata_only": { "const": true },
    "reporting_only": { "const": true },
    "native_execution_performed": { "const": false },
    "python_reference_execution_performed": { "const": false },
    "native_cpu_execution_performed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "cuda_source_modified": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "device_kernel_arithmetic_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "benchmark_execution_allowed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "generated_body_publication_allowed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "raw_data_processed": { "const": false },
    "method_status_upgrade_allowed": { "const": false },
    "method_status_upgraded": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true }
  }
}
