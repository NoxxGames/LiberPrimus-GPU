{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/prime-minus-one-native-parity-report-record-v0.schema.json",
  "title": "Prime Minus One Native Parity Report Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "source_stage_id",
    "contract_id",
    "candidate_batch_abi_id",
    "mapping_id",
    "native_parity_status",
    "hash_match",
    "compact_summary_only",
    "generated_body_publication_allowed",
    "method_status_upgrade_allowed",
    "native_execution_performed",
    "cuda_execution_performed",
    "cuda_source_modified",
    "new_cuda_kernels_added",
    "gpu_benchmark_performed",
    "solve_claim",
    "no_solve_claim"
  ],
  "properties": {
    "record_type": { "const": "prime_minus_one_native_parity_report_record" },
    "stage_id": { "const": "stage-5y" },
    "source_stage_id": { "const": "stage-5x" },
