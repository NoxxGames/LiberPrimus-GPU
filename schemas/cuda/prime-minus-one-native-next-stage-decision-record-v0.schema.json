{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/prime-minus-one-native-next-stage-decision-record-v0.schema.json",
  "title": "Prime Minus One Native Next Stage Decision Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "option_id",
    "status",
    "selected",
    "recommended_prompt_type",
    "recommended_stage_title",
    "rationale",
    "cuda_execution_allowed",
    "cuda_source_changes_allowed",
    "benchmark_execution_allowed",
    "unsolved_page_cuda_allowed",
    "generated_body_publication_allowed",
    "method_status_upgrade_allowed",
    "solve_claim",
    "no_solve_claim"
  ],
  "properties": {
    "record_type": { "const": "prime_minus_one_native_next_stage_decision_record" },
    "stage_id": { "const": "stage-5x" },
    "status": { "enum": ["selected", "blocked", "deferred"] },
    "recommended_prompt_type": { "enum": ["Codex", "Deep Research"] },
    "cuda_execution_allowed": { "const": false },
    "cuda_source_changes_allowed": { "const": false },
    "benchmark_execution_allowed": { "const": false },
    "benchmark_planning_allowed": { "const": false },
    "unsolved_page_cuda_allowed": { "const": false },
    "generated_body_publication_allowed": { "const": false },
    "method_status_upgrade_allowed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "cuda_source_modified": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "gpu_benchmark_performed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true }
  }
}
