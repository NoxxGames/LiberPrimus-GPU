    "candidate_batch_abi_id": { "const": "candidate_batch_abi_v0" },
    "cuda_execution_allowed": { "const": false },
    "generated_body_publication_allowed": { "const": false },
    "mapping_id": { "type": "string" },
    "mapping_status": { "type": "string" },
    "no_solve_claim": { "const": true },
    "record_type": { "const": "prime_minus_one_candidate_batch_mapping_record" },
    "solve_claim": { "const": false },
    "stage_id": { "const": "stage-5w" },
    "stream_schedule_ref": { "type": "string" },
    "stream_start_index": { "minimum": 0, "type": "integer" },
