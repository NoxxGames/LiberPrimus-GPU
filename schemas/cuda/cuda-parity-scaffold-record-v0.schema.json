{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://libreprimus-gpu.local/schemas/cuda/cuda-parity-scaffold-record-v0.schema.json",
  "title": "CUDA Parity Scaffold Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "stage_id",
    "scaffold_id",
    "target_id",
    "parity_scaffold_status",
    "execution_enabled",
    "cuda_execution_performed",
    "required_hash_checks",
    "cuda_planning_only",
    "cuda_implementation_added",
    "cuda_kernel_added",
    "cuda_source_modified",
    "gpu_benchmark_performed",
    "performance_claim",
    "speedup_claim",
    "broad_experiment_executed",
    "raw_data_processed",
    "solve_claim",
    "no_solve_claim",
    "canonical_corpus_active",
    "page_boundaries_final",
    "generated_outputs_committed",
    "codex_output_committed"
  ],
  "properties": {
    "record_type": { "const": "cuda_parity_scaffold" },
    "stage_id": { "const": "stage-5a" },
    "scaffold_id": { "type": "string", "minLength": 1 },
    "target_id": { "type": "string", "minLength": 1 },
    "parity_scaffold_status": { "enum": ["planned", "blocked", "deferred", "not_applicable"] },
    "execution_enabled": { "const": false },
    "cuda_execution_performed": { "const": false },
    "required_hash_checks": { "type": "array", "items": { "type": "string" } },
    "cuda_planning_only": { "const": true },
    "cuda_implementation_added": { "const": false },
    "cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false }
  }
}
