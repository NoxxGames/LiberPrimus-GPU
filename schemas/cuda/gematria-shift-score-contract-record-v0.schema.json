{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/cuda/gematria-shift-score-contract-record-v0.schema.json",
  "title": "Stage 5H Gematria shift score contract record",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "contract_id",
    "selected_future_kernel_id",
    "current_stage5f_kernel_scope",
    "production_contract_scope",
    "token_domain",
    "token_domain_min",
    "token_domain_max",
    "separator_policy",
    "arithmetic_direction",
    "arithmetic_formula",
    "candidate_shifts",
    "score_summary_required_for_future_cuda",
    "stage5h_cuda_execution_allowed",
    "solved_fixture_cuda_execution_allowed",
    "no_solve_claim"
  ],
  "properties": {
    "record_type": { "const": "gematria_shift_score_contract_record" },
    "stage_id": { "const": "stage-5h" },
    "contract_id": { "const": "gematria_mod29_shift_score_contract_v0" },
    "selected_future_kernel_id": { "const": "shift_score_kernel" },
    "current_stage5f_kernel_scope": { "const": "synthetic_uppercase_latin_only" },
    "production_contract_scope": { "const": "numeric_gematria_mod29_tokens" },
    "token_domain": { "const": "integers_0_to_28" },
    "token_domain_min": { "const": 0 },
    "token_domain_max": { "const": 28 },
    "separator_policy": { "const": "non_transformable_separators_preserved_unshifted" },
    "arithmetic_direction": { "const": "forward_add_shift_mod29" },
    "arithmetic_formula": { "const": "(token + shift) % 29" },
    "candidate_shifts": { "type": "array", "minItems": 5, "items": { "type": "integer", "minimum": 0, "maximum": 28 } },
    "score_summary_required_for_future_cuda": { "const": true },
    "stage5h_cuda_execution_allowed": { "const": false },
    "solved_fixture_cuda_execution_allowed": { "const": false },
    "production_gematria_mod29_cuda_ready": { "const": false },
    "real_liber_primus_data_used": { "const": false },
    "solved_fixture_cuda_used": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "cuda_kernel_added": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "cuda_source_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "broad_experiment_executed": { "const": false },
    "raw_data_processed": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "website_expansion": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "local_16gb_profile_required": { "const": false },
    "ci_gpu_required": { "const": false },
    "no_gpu_ci_safe": { "const": true },
    "python_semantic_reference_preserved": { "const": true },
    "cxx_launches_python_workers": { "const": false },
    "device_code_subset_must_remain_compliant": { "const": true },
    "gematria_mod29_contract_defined": { "const": true }
  },
  "additionalProperties": true
}
