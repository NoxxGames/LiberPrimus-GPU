{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noxxgames.github.io/LiberPrimus-GPU/schemas/cuda/gematria-solved-fixture-cuda-report-record-v0.schema.json",
  "title": "Gematria Solved-Fixture CUDA Report Record v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "record_type",
    "report_record_id",
    "mapping_id",
    "fixture_id",
    "original_transform_family",
    "executed_kernel",
    "executed_semantics",
    "native_hash",
    "cuda_hash",
    "parity_status",
    "output_hash_algorithm",
    "unsolved_page_cuda_used",
    "real_liber_primus_cuda_data_used",
    "gpu_benchmark_performed",
    "speedup_claim",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "gematria_solved_fixture_cuda_report_record" },
    "report_record_id": { "type": "string" },
    "mapping_id": { "type": "string" },
    "fixture_id": { "type": "string" },
    "original_transform_family": { "type": "string" },
    "executed_kernel": { "const": "gematria_mod29_shift_score_kernel" },
    "executed_semantics": { "const": "gematria_shift_score_only" },
    "native_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "cuda_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "parity_status": { "enum": ["passed", "failed_hash_mismatch", "failed_cuda_run", "skipped_missing_cuda", "skipped_not_requested", "unknown"] },
    "output_hash_algorithm": { "const": "sha256_canonical_json_v1" },
    "not_production_broad_cuda_readiness": { "const": true },
    "additional_cuda_execution_performed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "solved_fixture_cuda_used": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "real_liber_primus_cuda_data_used": { "const": false },
    "real_liber_primus_data_used": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "cuda_source_modified": { "const": false },
    "device_kernel_arithmetic_modified": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "performance_claim": { "const": false },
    "speedup_claim": { "const": false },
    "performance_or_speedup_claims": { "const": false },
    "raw_data_processed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "cxx_launches_python_workers": { "const": false },
    "no_solve_claim": { "const": true },
    "solve_claim": { "const": false }
  }
}
