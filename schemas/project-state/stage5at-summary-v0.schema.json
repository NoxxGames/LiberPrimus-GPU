{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/project-state/stage5at-summary-v0.schema.json",
  "type": "object",
  "required": ["record_type", "stage_id", "status", "cuda_execution_performed", "solve_claim"],
  "properties": {
    "record_type": { "enum": ["stage5at_token_case_review_pack_summary", "stage5at_next_stage_decision"] },
    "stage_id": { "const": "stage-5at" },
    "status": { "const": "complete" },
    "case_review_challenge_count": { "type": "integer", "minimum": 1 },
    "canonical_transcription_changed": { "const": false },
    "generated_review_pack_committed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "solve_claim": { "const": false }
  }
}
