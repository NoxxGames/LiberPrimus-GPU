{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/project-state/stage5dr-gui-refinement-summary-v0.schema.json",
  "title": "Stage 5DR GUI refinement summary",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "stage_title",
    "prompt_type",
    "canonical_codex_handoff_root",
    "layout",
    "detail_tabs",
    "view_menu_action",
    "toolbar_action",
    "table_context_menu_actions",
    "solve_claim",
    "execution_performed",
    "ocr_performed",
    "image_forensics_performed",
    "source_lock_record_semantics_rewritten"
  ],
  "properties": {
    "record_type": { "const": "stage5dr_gui_refinement_summary" },
    "stage_id": { "const": "stage-5dr" },
    "prompt_type": { "const": "codex_gui_implementation" },
    "canonical_codex_handoff_root": { "const": "codex-output" },
    "layout": { "const": "bottom_detail_panel_spanning_category_list_and_table" },
    "detail_tabs": {
      "type": "array",
      "contains": { "const": "Raw record" }
    },
    "view_menu_action": { "const": "Show Details Panel" },
    "toolbar_action": { "const": "Toggle Details" },
    "solve_claim": { "const": false },
    "execution_performed": { "const": false },
    "ocr_performed": { "const": false },
    "image_forensics_performed": { "const": false },
    "route_extraction_performed_now": { "const": false },
    "source_lock_record_semantics_rewritten": { "const": false },
    "committed_stage_records_modified_by_gui": { "const": false },
    "raw_source_files_mutated_by_gui": { "const": false }
  },
  "additionalProperties": true
}
