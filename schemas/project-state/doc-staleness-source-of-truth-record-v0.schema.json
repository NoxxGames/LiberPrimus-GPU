{
  "$id": "schemas/project-state/doc-staleness-source-of-truth-record-v0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "benchmark_performed": {
      "const": false
    },
    "canonical_corpus_status": {
      "const": "inactive"
    },
    "codex_output_committed": {
      "const": false
    },
    "cuda_execution_performed": {
      "type": "boolean"
    },
    "cuda_source_modified": {
      "const": false
    },
    "expected_next_stage_prefix": {
      "pattern": "Stage (5[A-Z]+(-fix)?|6[A-Z]?)",
      "type": "string"
    },
    "generated_outputs_committed": {
      "const": false
    },
    "latest_completed_stage_after_this_stage": {
      "pattern": "Stage (5[A-Z]+(-fix)?|6[A-Z]?)",
      "type": "string"
    },
    "latest_completed_stage_prefix": {
      "pattern": "Stage (5[A-Z]+(-fix)?|6[A-Z]?)",
      "type": "string"
    },
    "latest_previous_stage": {
      "pattern": "Stage (5[A-Z]+(-fix)?|6[A-Z]?)",
      "type": "string"
    },
    "new_cuda_kernels_added": {
      "const": 0
    },
    "next_stage_after_this_stage": {
      "pattern": "Stage (5[A-Z]+(-fix)?|6[A-Z]?)",
      "type": "string"
    },
    "page_boundaries_status": {
      "const": "reviewable"
    },
    "raw_data_processed": {
      "const": false
    },
    "record_type": {
      "const": "doc_staleness_source_of_truth_record"
    },
    "scored_experiments_executed": {
      "const": false
    },
    "scored_experiments_status": {
      "const": "deferred_manifest_gate_required"
    },
    "solve_claim": {
      "const": false
    },
    "stage_id": {
      "enum": [
        "stage-5ab",
        "stage-5ac",
        "stage-5ad",
        "stage-5ad-fix",
        "stage-5ae",
        "stage-5af",
        "stage-5ag",
        "stage-5ah",
        "stage-5eg",
        "stage-5eh",
        "stage-5ei",
        "stage-6",
        "stage-6b",
        "stage-6c"
      ]
    },
    "unsolved_page_cuda_status": {
      "const": "blocked"
    },
    "user_override_reason": {
      "minLength": 1,
      "type": "string"
    },
    "website_expansion_performed": {
      "const": false
    },
    "website_expansion_status": {
      "const": "deferred_future_unnumbered_project"
    }
  },
  "required": [
    "record_type",
    "stage_id",
    "latest_completed_stage_after_this_stage",
    "next_stage_after_this_stage",
    "website_expansion_status",
    "unsolved_page_cuda_status",
    "canonical_corpus_status",
    "page_boundaries_status",
    "cuda_execution_performed",
    "cuda_source_modified",
    "new_cuda_kernels_added",
    "benchmark_performed",
    "scored_experiments_executed",
    "solve_claim"
  ],
  "title": "Doc Staleness Source Of Truth Record",
  "type": "object"
}
