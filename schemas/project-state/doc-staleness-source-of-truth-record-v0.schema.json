{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/project-state/doc-staleness-source-of-truth-record-v0.schema.json",
  "title": "Doc Staleness Source Of Truth Record",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "latest_completed_stage_after_this_stage",
    "next_stage_after_this_stage",
    "website_expansion_status",
    "unsolved_page_cuda_status",
    "canonical_corpus_status",
    "page_boundaries_status",
    "cuda_execution_performed",
    "cuda_source_modified",
    "new_cuda_kernels_added",
    "benchmark_performed",
    "scored_experiments_executed",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "doc_staleness_source_of_truth_record" },
    "stage_id": { "enum": ["stage-5ab", "stage-5ac", "stage-5ad", "stage-5ad-fix", "stage-5ae"] },
    "latest_completed_stage_after_this_stage": { "type": "string", "pattern": "Stage 5A(B|C|D|E)(-fix)?" },
    "latest_completed_stage_prefix": { "enum": ["Stage 5AB", "Stage 5AC", "Stage 5AD", "Stage 5AD-fix", "Stage 5AE"] },
    "next_stage_after_this_stage": { "type": "string", "pattern": "Stage 5A(C|D|E|F)(-fix)?" },
    "expected_next_stage_prefix": { "enum": ["Stage 5AC", "Stage 5AD", "Stage 5AE", "Stage 5AF"] },
    "latest_previous_stage": { "type": "string", "pattern": "Stage 5A(A|B|C|D)(-fix)?" },
    "user_override_reason": { "type": "string", "minLength": 1 },
    "website_expansion_status": { "const": "deferred_future_unnumbered_project" },
    "scored_experiments_status": { "const": "deferred_manifest_gate_required" },
    "unsolved_page_cuda_status": { "const": "blocked" },
    "canonical_corpus_status": { "const": "inactive" },
    "page_boundaries_status": { "const": "reviewable" },
    "cuda_execution_performed": { "type": "boolean" },
    "cuda_source_modified": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "benchmark_performed": { "const": false },
    "scored_experiments_executed": { "const": false },
    "website_expansion_performed": { "const": false },
    "raw_data_processed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
