    "deep_research_readiness": { "const": true },
    "token_experiments_executed": { "const": false },
    "variant_byte_streams_generated": { "const": false },
    "cuda_execution_performed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
