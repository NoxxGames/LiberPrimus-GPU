{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/local-source-root-inventory-record-v0.schema.json",
  "title": "Stage 5AG local source root inventory",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "source_stage_id",
    "source_root",
    "root_exists",
    "root_is_ignored",
    "total_files",
    "total_dirs",
    "total_size_bytes",
    "metadata_only",
    "raw_content_included",
    "solve_claim"
  ],
  "properties": {
    "record_type": { "const": "stage5ag_local_source_root_inventory" },
    "stage_id": { "const": "stage-5ag" },
    "source_stage_id": { "const": "stage-5af" },
    "source_root": { "type": "string" },
    "root_exists": { "type": "boolean" },
    "root_is_ignored": { "type": "boolean" },
    "status": { "enum": ["inventoried", "blocked_missing_source_root"] },
    "total_files": { "type": "integer", "minimum": 0 },
    "total_dirs": { "type": "integer", "minimum": 0 },
    "total_size_bytes": { "type": "integer", "minimum": 0 },
    "unsupported_archive_count": { "type": "integer", "minimum": 0 },
    "metadata_only": { "const": true },
    "raw_content_included": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
