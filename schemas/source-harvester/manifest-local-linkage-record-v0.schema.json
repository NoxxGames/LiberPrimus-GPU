{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/manifest-local-linkage-record-v0.schema.json",
  "title": "Stage 5AG manifest to local source linkage",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id", "solve_claim"],
  "properties": {
    "record_type": {
      "enum": ["stage5ag_manifest_local_linkage", "stage5ag_manifest_local_linkage_record"]
    },
    "stage_id": { "const": "stage-5ag" },
    "source_stage_id": { "const": "stage-5af" },
    "source_id": { "type": "string" },
    "local_match_status": {
      "enum": ["matched_exact", "matched_probable", "missing", "ambiguous", "not_expected_local"]
    },
    "matched_paths": { "type": "array", "items": { "type": "string" } },
    "manifest_records_consumed": { "type": "integer", "minimum": 0 },
    "matched_count": { "type": "integer", "minimum": 0 },
    "missing_count": { "type": "integer", "minimum": 0 },
    "ambiguous_count": { "type": "integer", "minimum": 0 },
    "unclassified_local_count": { "type": "integer", "minimum": 0 },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
