{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AJ UsefulFiles source manifest extension",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id", "network_fetch_performed", "online_repo_clone_performed", "google_drive_storage_used", "solve_claim"],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5aj" },
    "source_stage_id": { "const": "stage-5ai" },
    "local_source_records": { "type": "integer", "minimum": 0 },
    "new_url_source_records": { "type": "integer", "minimum": 0 },
    "network_fetch_performed": { "const": false },
    "online_repo_clone_performed": { "const": false },
    "google_drive_storage_used": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
