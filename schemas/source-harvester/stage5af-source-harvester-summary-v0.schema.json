{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/stage5af-source-harvester-summary-v0.schema.json",
  "title": "Stage 5AF source harvester summary",
  "type": "object",
  "required": [
    "record_type",
    "stage_id",
    "status",
    "source_stage_id",
    "source_manifest_records",
    "clue_target_category_records",
    "research_bundle_plan_records",
    "network_fetch_performed",
    "raw_downloads_committed",
    "raw_archives_processed",
    "cuda_execution_performed",
    "cuda_source_modified",
    "new_cuda_kernels_added",
    "gpu_benchmark_performed",
    "scored_experiment_executed",
    "solve_claim",
    "no_solve_claim"
  ],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5af" },
    "status": { "const": "complete" },
    "source_stage_id": { "const": "stage-5ae" },
    "source_manifest_records": { "type": "integer", "minimum": 1 },
    "clue_target_category_records": { "type": "integer", "minimum": 1 },
    "research_bundle_plan_records": { "type": "integer", "minimum": 1 },
    "network_fetch_performed": { "const": false },
    "live_web_scrape_performed": { "const": false },
    "raw_downloads_committed": { "const": false },
    "raw_archives_processed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "cuda_source_modified": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "full_p56_cuda_executed": { "const": false },
    "unsolved_page_cuda_used": { "const": false },
    "gpu_benchmark_performed": { "const": false },
    "benchmark_execution_allowed": { "const": false },
    "scored_experiment_executed": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "method_status_upgraded": { "const": false },
    "google_drive_storage_allowed": { "const": false },
    "local_storage_only": { "const": true },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true }
  },
  "additionalProperties": true
}
