{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/local-source-manifest-extension-record-v0.schema.json",
  "title": "Stage 5AG local source manifest extension",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id"],
  "properties": {
    "record_type": { "enum": ["stage5ag_local_source_manifest_extension", "stage5ag_local_source_manifest_extension_record"] },
    "stage_id": { "const": "stage-5ag" },
    "source_stage_id": { "const": "stage-5af" },
    "source_id": { "type": "string", "minLength": 1 },
    "source_type": { "const": "local_user_upload" },
    "priority": { "enum": ["A1", "A2", "B", "C", "deferred"] },
    "source_tier": {
      "enum": [
        "tier4_social_claim_or_screenshot",
        "unknown"
      ]
    },
    "collection_status": {
      "enum": ["local_inventory_candidate", "needs_manual_classification"]
    },
    "allow_network_fetch": { "const": false },
    "allow_dynamic_browser": { "const": false },
    "raw_commit_allowed": { "const": false },
    "google_drive_storage_allowed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
