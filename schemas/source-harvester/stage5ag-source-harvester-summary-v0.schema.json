{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/stage5ag-source-harvester-summary-v0.schema.json",
  "title": "Stage 5AG source harvester summary",
  "type": "object",
  "required": [
    "record_type",
