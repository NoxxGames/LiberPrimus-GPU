    "manifest_records_matched": { "type": "integer", "minimum": 0 },
    "manifest_records_missing": { "type": "integer", "minimum": 0 },
    "manifest_records_ambiguous": { "type": "integer", "minimum": 0 },
    "source_lock_candidates_ready": { "type": "integer", "minimum": 0 },
    "research_bundle_records": { "type": "integer", "minimum": 0 },
