  "required": ["record_type", "stage_id", "source_stage_id", "solve_claim"],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5ai" },
    "source_stage_id": { "const": "stage-5ah" },
    "status": { "enum": ["complete", "draft", "blocked"] },
    "website_expansion_performed": { "const": false },
    "network_fetch_performed": { "const": false },
    "live_web_scrape_performed": { "const": false },
    "online_repo_clone_performed": { "const": false },
    "google_drive_storage_used": { "const": false },
    "raw_data_committed": { "const": false },
    "generated_bundle_bodies_committed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "codex_output_committed": { "const": false },
    "ocr_performed": { "const": false },
    "ai_ml_interpretation_performed": { "const": false },
    "stego_tool_execution_performed": { "const": false },
    "image_forensics_performed": { "const": false },
    "audio_analysis_performed": { "const": false },
    "hypothesis_generation_performed": { "const": false },
    "hypothesis_execution_performed": { "const": false },
    "cuda_execution_performed": { "const": false },
    "cuda_source_modified": { "const": false },
    "new_cuda_kernel_added": { "const": false },
    "new_cuda_kernels_added": { "const": 0 },
    "gpu_benchmark_performed": { "const": false },
    "benchmark_execution_allowed": { "const": false },
    "scored_experiment_executed": { "const": false },
    "canonical_corpus_active": { "const": false },
    "page_boundaries_final": { "const": false },
    "method_status_upgraded": { "const": false },
    "solve_claim": { "const": false },
    "no_solve_claim": { "const": true }
  },
  "additionalProperties": true
}
