{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AJ UsefulFiles local inventory",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id", "local_folder_exists", "raw_data_committed", "generated_outputs_committed", "solve_claim"],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5aj" },
    "source_stage_id": { "const": "stage-5ai" },
    "local_folder_exists": { "type": "boolean" },
    "usefulfiles_local_file_count": { "type": "integer", "minimum": 0 },
    "raw_data_committed": { "const": false },
    "generated_outputs_committed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
