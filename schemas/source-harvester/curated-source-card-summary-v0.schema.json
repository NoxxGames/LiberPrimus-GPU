{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AI curated source card summary",
  "type": "object",
  "required": ["record_type", "stage_id", "source_card_records", "raw_content_publication_allowed", "generated_extract_publication_allowed", "solve_claim"],
  "properties": {
    "record_type": { "enum": ["stage5ai_curated_source_card_summary", "stage5ai_curated_source_card"] },
    "stage_id": { "const": "stage-5ai" },
    "source_card_records": { "type": "integer", "minimum": 0 },
    "raw_content_publication_allowed": { "const": false },
    "generated_extract_publication_allowed": { "const": false },
    "website_publication_allowed_count": { "type": "integer", "maximum": 0 },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
