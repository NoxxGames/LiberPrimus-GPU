{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AI unclassified source classification",
  "type": "object",
  "required": ["record_type", "stage_id", "evidence_status_upgraded", "solve_claim"],
  "properties": {
    "record_type": { "enum": ["stage5ai_unclassified_source_classification", "stage5ai_unclassified_source_classification_record"] },
    "stage_id": { "const": "stage-5ai" },
    "classification_records": { "type": "integer", "minimum": 0 },
    "provisional_bundle_ids": { "type": "array", "items": { "type": "string" } },
    "evidence_status_upgraded": { "const": false },
    "usable_as_evidence": { "const": false },
    "website_publication_allowed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
