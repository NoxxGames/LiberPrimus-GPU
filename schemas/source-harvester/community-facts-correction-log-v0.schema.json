{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AK Community Facts Correction Log",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id", "source_id", "correction_record_count", "solve_claim"],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5ak" },
    "source_stage_id": { "const": "stage-5aj" },
    "source_id": { "const": "community_facts_observations_local" },
    "correction_record_count": { "type": "integer", "minimum": 0 },
    "arithmetic_error_count": { "type": "integer", "minimum": 0 },
    "execution_ready": { "const": false },
    "website_publication_allowed": { "const": false },
    "deep_research_private_allowed": { "const": true },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
