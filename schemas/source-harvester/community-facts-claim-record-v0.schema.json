{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5AK Community Facts Claim Records",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id", "source_id", "claim_record_count", "execution_ready_count", "website_publication_allowed_count", "solve_claim"],
  "properties": {
    "record_type": { "type": "string" },
    "stage_id": { "const": "stage-5ak" },
    "source_stage_id": { "const": "stage-5aj" },
    "source_id": { "const": "community_facts_observations_local" },
    "claim_record_count": { "type": "integer", "minimum": 0 },
    "execution_ready": { "const": false },
    "execution_ready_count": { "const": 0 },
    "requires_null_controls": { "type": "boolean" },
    "website_publication_allowed": { "const": false },
    "website_publication_allowed_count": { "const": 0 },
    "deep_research_private_allowed": { "const": true },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
