{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/file-inventory-record-v0.schema.json",
  "title": "Stage 5AF file inventory record",
  "type": "object",
  "required": ["record_type", "stage_id", "source_id", "size_bytes", "sha256"],
  "properties": {
    "record_type": { "enum": ["file_inventory_record", "hash_inventory_record"] },
    "stage_id": { "const": "stage-5af" },
    "source_id": { "type": ["string", "null"] },
    "path": { "type": "string" },
    "archive_member_path": { "type": "string" },
    "size_bytes": { "type": "integer", "minimum": 0 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "mime_guess": { "type": "string" },
    "raw_file_committed": { "const": false },
    "archive_extracted": { "const": false },
    "generated_outputs_committed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
