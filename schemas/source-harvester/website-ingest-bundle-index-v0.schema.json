{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Website ingest bundle index",
  "type": "object",
  "required": ["record_type", "stage_id", "website_expansion_performed", "solve_claim"],
  "properties": {
    "record_type": { "enum": ["stage5ai_website_ingest_index", "stage5ai_website_ingest_format"] },
    "stage_id": { "const": "stage-5ai" },
    "website_ingest_metadata_ready": { "type": "boolean" },
    "public_website_ready_count": { "type": "integer", "maximum": 0 },
    "website_expansion_performed": { "const": false },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
