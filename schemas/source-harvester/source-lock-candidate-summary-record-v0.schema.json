{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/source-lock-candidate-summary-record-v0.schema.json",
  "title": "Stage 5AG source-lock candidate summary",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id", "solve_claim"],
  "properties": {
    "record_type": {
      "enum": ["stage5ag_source_lock_candidate_summary", "stage5ag_source_lock_candidate_record"]
    },
    "stage_id": { "const": "stage-5ag" },
    "source_stage_id": { "const": "stage-5af" },
    "candidate_status": {
      "enum": [
        "ready_for_source_lock_inventory",
        "needs_manual_export",
        "needs_manual_classification",
        "unsupported_archive_type",
        "duplicate_or_redundant",
        "missing"
      ]
    },
    "metadata_only": { "const": true },
    "raw_content_committed": { "const": false },
    "ready_count": { "type": "integer", "minimum": 0 },
    "needs_review_count": { "type": "integer", "minimum": 0 },
    "missing_count": { "type": "integer", "minimum": 0 },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
