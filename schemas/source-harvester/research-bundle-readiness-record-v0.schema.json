{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/source-harvester/research-bundle-readiness-record-v0.schema.json",
  "title": "Stage 5AG research bundle readiness",
  "type": "object",
  "required": ["record_type", "stage_id", "source_stage_id", "solve_claim"],
  "properties": {
    "record_type": {
      "enum": ["stage5ag_research_bundle_readiness", "stage5ag_research_bundle_readiness_record"]
    },
    "stage_id": { "const": "stage-5ag" },
    "source_stage_id": { "const": "stage-5af" },
    "bundle_id": { "type": "string" },
    "readiness_status": {
      "enum": ["ready_for_extraction_prep", "partially_ready", "not_ready"]
    },
    "bundle_records": { "type": "integer", "minimum": 0 },
    "ready_for_extraction_prep_count": { "type": "integer", "minimum": 0 },
    "partial_count": { "type": "integer", "minimum": 0 },
    "not_ready_count": { "type": "integer", "minimum": 0 },
    "solve_claim": { "const": false }
  },
  "additionalProperties": true
}
