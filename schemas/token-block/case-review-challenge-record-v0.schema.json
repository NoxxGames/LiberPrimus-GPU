{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/token-block/case-review-challenge-record-v0.schema.json",
  "type": "object",
  "required": ["record_type", "stage_id", "challenge_count", "records", "canonical_transcription_changed", "canonical_transcription_change_allowed", "solve_claim"],
  "properties": {
    "record_type": { "const": "case_review_challenge_set" },
    "stage_id": { "const": "stage-5at" },
    "challenge_count": { "type": "integer", "minimum": 1 },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["challenge_id", "token_index_0_based", "canonical_token", "candidate_tokens", "original_image_id", "bbox", "review_status", "decision_status"],
        "properties": {
          "candidate_tokens": { "type": "array", "minItems": 1 },
          "review_status": { "const": "human_review_required" },
          "decision_status": { "const": "unresolved" },
          "canonical_transcription_change_allowed": { "const": false },
          "solve_claim": { "const": false }
        }
      }
    },
    "canonical_transcription_changed": { "const": false },
    "canonical_transcription_change_allowed": { "const": false },
    "solve_claim": { "const": false }
  }
}
